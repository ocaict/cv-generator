<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .accordion-header svg { transition: transform 0.3s ease; }
    .quill-content p, #preview-content p { margin-bottom: 0.5rem; }
    .quill-content p:last-child, #preview-content p:last-child { margin-bottom: 0; }
    .quill-content ul, #preview-content ul { list-style-type: disc; padding-left: 1.25rem; margin-bottom: 0.5rem; }
    
    /* Restore layout elements but keep sidebar scrolling clean */
    footer { display: none !important; }
    main { padding-top: 0 !important; padding-bottom: 0 !important; }
    #preview-section { scroll-behavior: smooth; }
</style>
<link id="google-fonts-link" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Inter:wght@400;500;600&family=EB+Garamond:wght@400;600;700&display=swap" rel="stylesheet">
<div class="h-[calc(100vh-64px)] flex flex-col lg:flex-row overflow-hidden bg-gray-50 uppercase-tracking-widest">
    <!-- Left Sidebar: Controls -->
    <div id="sidebar" class="w-full lg:w-1/3 lg:min-w-[450px] h-full overflow-y-auto bg-white border-r border-gray-100 flex flex-col p-6 lg:p-10 pb-32">
         <div class="flex items-center justify-between mb-8">
            <h1 class="text-2xl font-bold font-outfit text-gray-900 truncate pr-4"><%= cv.title %></h1>
             <div class="flex flex-col items-end space-y-3">
                <div class="flex items-center space-x-3">
                    <button id="save-btn" class="bg-white border border-gray-200 text-gray-600 px-5 py-2 rounded-xl text-xs font-bold shadow-sm hover:shadow-md transition-all flex items-center space-x-2">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 1l-3 3m0 0l-3-3m3 3V3"></path></svg>
                        <span>Save</span>
                    </button>
                    <button id="export-btn" class="bg-indigo-600 text-white px-5 py-2 rounded-xl text-xs font-bold shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all flex items-center space-x-2">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        <span>Export PDF</span>
                    </button>
                </div>
                <div class="flex items-center space-x-2 text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1 pr-1" id="save-status">
                    <div class="w-1.5 h-1.5 rounded-full bg-green-500" id="save-status-indicator"></div>
                    <span id="save-status-text">Saved</span>
                </div>
            </div>
        </div>

        <!-- Stepper -->
        <div class="flex items-center justify-between mb-10 px-2 bg-gray-50/50 p-4 rounded-2xl border border-gray-100/50">
            <button type="button" class="step-btn active group" data-step="1">
                <div class="w-8 h-8 rounded-lg bg-indigo-600 text-white flex items-center justify-center font-bold text-xs shadow-lg shadow-indigo-100 transition-all group-hover:scale-110">1</div>
                <span class="text-[9px] font-bold text-indigo-600 mt-2 block uppercase tracking-widest text-center">Info</span>
            </button>
            <div class="h-px w-3 bg-gray-200 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="2">
                <div class="w-8 h-8 rounded-lg bg-white border-2 border-gray-100 text-gray-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 group-hover:text-indigo-600">2</div>
                <span class="text-[9px] font-bold text-gray-400 mt-2 block uppercase tracking-widest text-center">Work</span>
            </button>
            <div class="h-px w-3 bg-gray-200 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="3">
                <div class="w-8 h-8 rounded-lg bg-white border-2 border-gray-100 text-gray-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 group-hover:text-indigo-600">3</div>
                <span class="text-[9px] font-bold text-gray-400 mt-2 block uppercase tracking-widest text-center">Edu</span>
            </button>
            <div class="h-px w-3 bg-gray-200 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="4">
                <div class="w-8 h-8 rounded-lg bg-white border-2 border-gray-100 text-gray-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 group-hover:text-indigo-600">4</div>
                <span class="text-[9px] font-bold text-gray-400 mt-2 block uppercase tracking-widest text-center">Skills</span>
            </button>
            <div class="h-px w-3 bg-gray-200 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="5">
                <div class="w-8 h-8 rounded-lg bg-white border-2 border-gray-100 text-gray-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 group-hover:text-indigo-600">5</div>
                <span class="text-[9px] font-bold text-gray-400 mt-2 block uppercase tracking-widest text-center">More</span>
            </button>
            <div class="h-px w-3 bg-gray-200 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="6">
                <div class="w-8 h-8 rounded-lg bg-white border-2 border-gray-100 text-gray-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 group-hover:text-indigo-600">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-3"></path></svg>
                </div>
                <span class="text-[9px] font-bold text-gray-400 mt-2 block uppercase tracking-widest text-center">Design</span>
            </button>
        </div>

        <form id="editor-form" class="flex-grow flex flex-col">
            <!-- Step 1: Personal Info -->
            <div id="step-form-1" class="step-form animate-fade-in space-y-12">
                <section>
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            <span>Personal Details</span>
                        </h3>
                    </div>

                    <!-- Profile Photo -->
                    <div class="flex items-center space-x-6 mb-10 p-6 bg-indigo-50/30 rounded-3xl border border-indigo-100/50 group transition-all hover:bg-indigo-50/50">
                        <div class="relative">
                            <div id="photo-preview" class="w-24 h-24 rounded-2xl bg-white border-2 border-dashed border-indigo-200 flex items-center justify-center overflow-hidden shadow-inner group-hover:border-indigo-400 transition-all">
                                <% if (cvData.personalInfo && cvData.personalInfo.photo) { %>
                                    <img src="<%= cvData.personalInfo.photo %>" class="w-full h-full object-cover">
                                <% } else { %>
                                    <svg class="w-8 h-8 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                <% } %>
                            </div>
                            <button type="button" id="remove-photo" class="<%= (cvData.personalInfo && cvData.personalInfo.photo) ? '' : 'hidden' %> absolute -top-2 -right-2 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center shadow-lg hover:bg-red-600 transition-all text-xs font-bold">×</button>
                        </div>
                        <div class="flex-grow">
                            <h4 class="text-xs font-bold text-gray-900 mb-1">Profile Photo</h4>
                            <p class="text-[10px] text-gray-400 font-medium mb-3">Upload a professional photo (JPG, PNG). Max 2MB.</p>
                            <input type="file" id="photo-input" accept="image/*" class="hidden">
                            <button type="button" onclick="document.getElementById('photo-input').click()" class="bg-white border border-indigo-200 text-indigo-600 px-4 py-2 rounded-xl text-[10px] font-bold shadow-sm hover:border-indigo-400 hover:text-indigo-700 transition-all uppercase tracking-widest">Select Image</button>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">First Name</label>
                            <input type="text" name="personalInfo.firstName" value="<%= cvData.personalInfo.firstName || '' %>" placeholder="e.g. John" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Last Name</label>
                            <input type="text" name="personalInfo.lastName" value="<%= cvData.personalInfo.lastName || '' %>" placeholder="e.g. Doe" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Job Title</label>
                            <input type="text" name="personalInfo.jobTitle" value="<%= cvData.personalInfo.jobTitle %>" placeholder="e.g. Sales Manager" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Email Address</label>
                            <input type="email" name="personalInfo.email" value="<%= cvData.personalInfo.email || '' %>" placeholder="e.g. john@example.com" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Phone Number</label>
                            <input type="tel" name="personalInfo.phone" value="<%= cvData.personalInfo.phone || '' %>" placeholder="e.g. +1 234..." class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Address</label>
                            <input type="text" name="personalInfo.address" value="<%= cvData.personalInfo.address || '' %>" placeholder="e.g. 123 Main St" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                        </div>
                        <div class="col-span-2 grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Zip Code</label>
                                <input type="text" name="personalInfo.zipCode" value="<%= cvData.personalInfo.zipCode || '' %>" placeholder="e.g. 123456" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">City/Town</label>
                                <input type="text" name="personalInfo.city" value="<%= cvData.personalInfo.city || '' %>" placeholder="e.g. London" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none">
                            </div>
                        <div class="col-span-2 pt-4">
                            <label class="block text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-widest">Global AI Writing Tone</label>
                            <select name="aiTone" id="ai-tone-selector" class="w-full px-4 py-3 bg-indigo-50 border border-indigo-100 rounded-xl focus:ring-2 focus:ring-indigo-500 text-xs font-bold text-indigo-700 outline-none cursor-pointer transition-all hover:bg-indigo-100/50">
                                <option value="Professional" <%= (cvData.aiTone === 'Professional') ? 'selected' : '' %>>🤝 Professional (Balanced & Standard)</option>
                                <option value="Executive" <%= (cvData.aiTone === 'Executive') ? 'selected' : '' %>>💼 Executive (Strong & Authoritative)</option>
                                <option value="Creative" <%= (cvData.aiTone === 'Creative') ? 'selected' : '' %>>🎨 Creative (Personal & Narrative)</option>
                                <option value="Concise" <%= (cvData.aiTone === 'Concise') ? 'selected' : '' %>>⚡ Concise (Sharp & Bullet-focused)</option>
                            </select>
                        </div>

                        <!-- Additional Info Toggle -->
                        <div class="col-span-2 pt-4">
                            <button type="button" id="toggle-additional-info" class="w-full py-4 border-y border-gray-100 flex items-center justify-center space-x-2 text-indigo-600 font-bold text-xs uppercase tracking-widest hover:bg-gray-50 transition-all">
                                <span id="toggle-icon">+</span>
                                <span>Additional Information</span>
                            </button>
                        </div>

                        <div id="additional-info-panel" class="col-span-2 grid grid-cols-2 gap-4 hidden py-4 animate-fade-in text-left">
                            <div class="col-span-2 sm:col-span-1">
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Date of Birth</label>
                                <div class="grid grid-cols-3 gap-2">
                                    <select name="personalInfo.dobDay" class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 text-[10px] outline-none">
                                        <option value="">Day</option>
                                        <% for(let i=1; i<=31; i++) { %>
                                            <option value="<%= i %>" <%= (cvData.personalInfo.dobDay == i) ? 'selected' : '' %>><%= i %></option>
                                        <% } %>
                                    </select>
                                    <select name="personalInfo.dobMonth" class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 text-[10px] outline-none">
                                        <option value="">Month</option>
                                        <% ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"].forEach(m => { %>
                                            <option value="<%= m %>" <%= (cvData.personalInfo.dobMonth == m) ? 'selected' : '' %>><%= m %></option>
                                        <% }) %>
                                    </select>
                                    <select name="personalInfo.dobYear" class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 text-[10px] outline-none">
                                        <option value="">Year</option>
                                        <% const currYear = new Date().getFullYear(); for(let i=currYear; i>=currYear-80; i--) { %>
                                            <option value="<%= i %>" <%= (cvData.personalInfo.dobYear == i) ? 'selected' : '' %>><%= i %></option>
                                        <% } %>
                                    </select>
                                </div>
                            </div>
                            <div class="col-span-2 sm:col-span-1">
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Nationality</label>
                                <input type="text" name="personalInfo.nationality" value="<%= cvData.personalInfo.nationality || '' %>" placeholder="e.g. USA" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all text-xs outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Marital Status</label>
                                <input type="text" name="personalInfo.maritalStatus" value="<%= cvData.personalInfo.maritalStatus || '' %>" placeholder="e.g. Single" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all text-xs outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Driving License</label>
                                <input type="text" name="personalInfo.drivingLicense" value="<%= cvData.personalInfo.drivingLicense || '' %>" placeholder="e.g. Class A" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all text-xs outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">LinkedIn</label>
                                <input type="text" name="personalInfo.linkedin" value="<%= cvData.personalInfo.linkedin || '' %>" placeholder="linkedin.com/..." class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all text-xs outline-none">
                            </div>
                             <div>
                                <label class="block text-xs font-bold text-gray-500 mb-2 uppercase">Website</label>
                                <input type="text" name="personalInfo.website" value="<%= cvData.personalInfo.website || '' %>" placeholder="portfolio.com" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all text-xs outline-none">
                            </div>
                        </div>

                        <div class="col-span-2 pt-4">
                            <div class="flex items-center justify-between mb-2">
                                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest">Professional Summary</label>
                                <button type="button" class="ai-gen-btn text-[10px] font-bold text-indigo-600 uppercase tracking-tighter hover:scale-105 transition-all flex items-center space-x-1.5 px-3 py-1 bg-indigo-50 rounded-full" data-type="summary">
                                    <span>✨ AI Improve</span>
                                </button>
                            </div>
                            <div id="summary-editor" class="h-32 bg-gray-50 border border-gray-200 rounded-xl overflow-hidden shadow-inner text-sm"><%- cvData.personalInfo.summary %></div>
                            <input type="hidden" name="personalInfo.summary" value="<%= cvData.personalInfo.summary %>">
                        </div>
                    </div>
                </section>
                <div class="pt-8 mt-auto border-t border-gray-100 flex justify-end">
                    <button type="button" data-next="2" class="next-step-btn bg-indigo-600 text-white px-10 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Next Step &raquo;</button>
                </div>
            </div>

            <!-- Step 2: Work Experience -->
            <div id="step-form-2" class="step-form hidden animate-fade-in flex-grow flex flex-col">
                <section class="flex-grow">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                            <span>Work Experience</span>
                        </h3>
                        <button type="button" id="add-experience" class="text-indigo-600 font-bold text-xs uppercase hover:underline">+ Add Experience</button>
                    </div>
                    <div id="experience-list" class="space-y-4">
                        <!-- Dynamic items will be injected here -->
                    </div>
                </section>
                <div class="pt-8 mt-auto border-t border-gray-100 flex justify-between items-center">
                    <button type="button" data-prev="1" class="prev-step-btn text-gray-400 font-bold hover:text-indigo-600 transition-all">&laquo; Previous</button>
                    <button type="button" data-next="3" class="next-step-btn bg-indigo-600 text-white px-10 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Education &raquo;</button>
                </div>
            </div>

            <!-- Step 3: Education -->
            <div id="step-form-3" class="step-form hidden animate-fade-in flex-grow flex flex-col">
                <section class="flex-grow">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0v6m0-6L3 9m18 0l-9 5"></path>
                            </svg>
                            <span>Education</span>
                        </h3>
                        <button type="button" id="add-education" class="text-indigo-600 font-bold text-xs uppercase hover:underline">+ Add Education</button>
                    </div>
                    <div id="education-list" class="space-y-4">
                        <!-- Dynamic items -->
                    </div>
                </section>
                <div class="pt-8 mt-auto border-t border-gray-100 flex justify-between items-center">
                    <button type="button" data-prev="2" class="prev-step-btn text-gray-400 font-bold hover:text-indigo-600 transition-all">&laquo; Work Experience</button>
                    <button type="button" data-next="4" class="next-step-btn bg-indigo-600 text-white px-10 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Skills &raquo;</button>
                </div>
            </div>

            <!-- Step 4: Skills -->
            <div id="step-form-4" class="step-form hidden animate-fade-in flex-grow flex flex-col">
                <section class="flex-grow">
                    <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 uppercase tracking-widest mb-8">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        <span>Skills</span>
                    </h3>
                    <div class="space-y-8">
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest">Technical Skills</label>
                                <button type="button" class="ai-gen-btn text-[10px] font-bold text-indigo-600 uppercase tracking-tighter hover:scale-105 transition-all flex items-center space-x-1.5 px-3 py-1 bg-indigo-50 rounded-full" data-type="skills" data-target="skills.technical">
                                    <span>✨ AI Suggest</span>
                                </button>
                            </div>
                            <textarea name="skills.technical" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none h-24 resize-none" placeholder="e.g. JavaScript, Product Design, SQL..."><%= cvData.skills ? cvData.skills.technical.join(', ') : '' %></textarea>
                        </div>
                        <div>
                            <div class="flex items-center justify-between mb-2">
                                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest">Soft Skills</label>
                                <button type="button" class="ai-gen-btn text-[10px] font-bold text-indigo-600 uppercase tracking-tighter hover:scale-105 transition-all flex items-center space-x-1.5 px-3 py-1 bg-indigo-50 rounded-full" data-type="skills" data-target="skills.soft">
                                    <span>✨ AI Suggest</span>
                                </button>
                            </div>
                            <textarea name="skills.soft" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-indigo-500 transition-all outline-none h-24 resize-none" placeholder="e.g. Leadership, Team Management..."><%= cvData.skills ? cvData.skills.soft.join(', ') : '' %></textarea>
                        </div>
                    </div>
                </section>
                <div class="pt-8 mt-auto border-t border-gray-100 flex justify-between items-center">
                    <button type="button" data-prev="3" class="prev-step-btn text-gray-400 font-bold hover:text-indigo-600 transition-all">&laquo; Education</button>
                    <button type="button" data-next="5" class="next-step-btn bg-indigo-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Next Step &raquo;</button>
                </div>
            </div>

            <!-- Step 5: More (Interests & References) -->
            <div id="step-form-5" class="step-form hidden animate-fade-in flex-grow flex flex-col space-y-12">
                <!-- Interests Section -->
                <section>
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                            </svg>
                            <span>Interests & Hobbies</span>
                        </h3>
                    </div>
                    <div id="hobbies-list" class="space-y-4">
                        <!-- Hobby items will be added here -->
                    </div>
                    <button type="button" id="add-hobby" class="mt-6 w-full py-4 border-2 border-dashed border-gray-100 rounded-2xl text-xs font-bold text-gray-400 uppercase tracking-widest hover:border-indigo-200 hover:text-indigo-600 hover:bg-indigo-50/30 transition-all flex items-center justify-center space-x-2">
                        <span>+ Add Hobby</span>
                    </button>
                </section>

                <!-- References Section -->
                <section>
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                            </svg>
                            <span>References</span>
                        </h3>
                        <div class="flex items-center space-x-2">
                            <input type="checkbox" id="references-on-request" name="referencesOnRequest" <%= cvData.referencesOnRequest ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                            <label for="references-on-request" class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Available on request</label>
                        </div>
                    </div>
                    <div id="references-list" class="space-y-4">
                        <!-- Reference items will be added here -->
                    </div>
                    <button type="button" id="add-reference" class="mt-6 w-full py-4 border-2 border-dashed border-gray-100 rounded-2xl text-xs font-bold text-gray-400 uppercase tracking-widest hover:border-indigo-200 hover:text-indigo-600 hover:bg-indigo-50/30 transition-all flex items-center justify-center space-x-2">
                        <span>+ Add Reference</span>
                    </button>
                </section>

                <div class="pt-8 mt-auto border-t border-gray-100 flex justify-between items-center pb-10">
                    <button type="button" data-prev="4" class="prev-step-btn text-gray-400 font-bold hover:text-indigo-600 transition-all">&laquo; Skills</button>
                    <button type="button" data-next="6" class="next-step-btn bg-indigo-600 text-white px-10 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Design &raquo;</button>
                </div>
            </div>

            <!-- Step 6: Design & Layout -->
            <div id="step-form-6" class="step-form hidden animate-fade-in flex-grow flex flex-col space-y-12">
                <section>
                    <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 uppercase tracking-widest mb-8">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <span>Template & Color</span>
                    </h3>
                    
                    <div class="space-y-10">
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 mb-4 uppercase tracking-widest leading-none">Select Layout Template</label>
                            <div class="grid grid-cols-3 gap-3">
                                <label class="cursor-pointer group">
                                    <input type="radio" name="templateId" value="modern" class="hidden peer" <%= cv.templateId === 'modern' ? 'checked' : '' %>>
                                    <div class="p-3 border-2 border-gray-100 rounded-2xl group-hover:border-indigo-200 peer-checked:border-indigo-600 peer-checked:bg-indigo-50 transition-all text-center">
                                        <div class="h-20 bg-gray-50 rounded-xl mb-2 overflow-hidden flex flex-col items-center justify-center space-y-1.5 border border-gray-100">
                                            <div class="w-10 h-1 bg-gray-200 rounded-full"></div>
                                            <div class="flex space-x-1">
                                                <div class="w-3 h-6 bg-gray-200 rounded-sm"></div>
                                                <div class="w-6 h-6 bg-gray-100 rounded-sm"></div>
                                            </div>
                                        </div>
                                        <span class="text-[9px] font-bold text-gray-500 uppercase tracking-tight">Modern</span>
                                    </div>
                                </label>
                                <label class="cursor-pointer group">
                                    <input type="radio" name="templateId" value="classic" class="hidden peer" <%= cv.templateId === 'classic' ? 'checked' : '' %>>
                                    <div class="p-3 border-2 border-gray-100 rounded-2xl group-hover:border-indigo-200 peer-checked:border-indigo-600 peer-checked:bg-indigo-50 transition-all text-center">
                                        <div class="h-20 bg-gray-50 rounded-xl mb-2 overflow-hidden flex flex-col items-center justify-center space-y-1.5 border border-gray-100">
                                            <div class="w-10 h-1.5 bg-gray-200 rounded-full"></div>
                                            <div class="w-12 h-0.5 bg-gray-100 rounded-full"></div>
                                            <div class="w-12 h-0.5 bg-gray-100 rounded-full"></div>
                                            <div class="w-12 h-0.5 bg-gray-100 rounded-full"></div>
                                        </div>
                                        <span class="text-[9px] font-bold text-gray-500 uppercase tracking-tight">Classic</span>
                                    </div>
                                </label>
                                <label class="cursor-pointer group">
                                    <input type="radio" name="templateId" value="minimalist" class="hidden peer" <%= cv.templateId === 'minimalist' ? 'checked' : '' %>>
                                    <div class="p-3 border-2 border-gray-100 rounded-2xl group-hover:border-indigo-200 peer-checked:border-indigo-600 peer-checked:bg-indigo-50 transition-all text-center">
                                        <div class="h-20 bg-gray-50 rounded-xl mb-2 overflow-hidden flex flex-col items-center justify-center space-y-1 border border-gray-100 px-2">
                                            <div class="w-8 h-1 bg-gray-300 rounded-full"></div>
                                            <div class="w-full h-0.5 bg-gray-100 rounded-full"></div>
                                            <div class="w-full h-0.5 bg-gray-100 rounded-full"></div>
                                            <div class="w-full h-0.5 bg-gray-100 rounded-full"></div>
                                            <div class="w-full h-0.5 bg-gray-100 rounded-full"></div>
                                        </div>
                                        <span class="text-[9px] font-bold text-gray-500 uppercase tracking-tight">Minimal</span>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <label class="block text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-widest leading-none">Typography Style</label>
                                <select name="fontPairing" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 text-xs font-bold text-gray-700 outline-none focus:border-indigo-600 transition-all appearance-none">
                                    <option value="outfit-inter" <%= cv.fontPairing === 'outfit-inter' ? 'selected' : '' %>>Modern (Outfit + Inter)</option>
                                    <option value="serif-inter" <%= cv.fontPairing === 'serif-inter' ? 'selected' : '' %>>Professional (Serif + Inter)</option>
                                    <option value="inter-inter" <%= cv.fontPairing === 'inter-inter' ? 'selected' : '' %>>Standard (Inter + Inter)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-widest leading-none">Content Density</label>
                                <select name="density" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 text-xs font-bold text-gray-700 outline-none focus:border-indigo-600 transition-all appearance-none">
                                    <option value="tight" <%= cv.density === 'tight' ? 'selected' : '' %>>Compact</option>
                                    <option value="standard" <%= cv.density === 'standard' ? 'selected' : '' %>>Standard</option>
                                    <option value="airy" <%= cv.density === 'airy' ? 'selected' : '' %>>Airy (Premium)</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 mb-4 uppercase tracking-widest leading-none">Primary Accent Color</label>
                            <div class="flex flex-wrap gap-4 items-center">
                                <% const colors = [
                                    { name: 'Indigo', hex: '#4f46e5' },
                                    { name: 'Sky', hex: '#0ea5e9' },
                                    { name: 'Emerald', hex: '#10b981' },
                                    { name: 'Amber', hex: '#f59e0b' },
                                    { name: 'Rose', hex: '#f43f5e' },
                                    { name: 'Slate', hex: '#475569' }
                                ] %>
                                <% colors.forEach(color => { %>
                                    <label class="relative cursor-pointer group">
                                        <input type="radio" name="themeColor" value="<%= color.hex %>" class="hidden peer" <%= (cvData.themeColor || '#4f46e5') === color.hex ? 'checked' : '' %>>
                                        <div class="w-10 h-10 rounded-xl border-2 border-white ring-2 ring-transparent peer-checked:ring-indigo-600 peer-checked:scale-110 shadow-sm transition-all group-hover:scale-105" style="background-color: <%= color.hex %>;"></div>
                                    </label>
                                <% }) %>
                                <div class="flex flex-col items-center space-y-2 ml-2">
                                    <input type="color" name="themeColorCustom" id="custom-color-picker" class="w-10 h-10 rounded-xl border-2 border-gray-100 p-1 cursor-pointer bg-white shadow-sm" value="<%= cvData.themeColor || '#4f46e5' %>">
                                    <span class="text-[8px] font-bold text-gray-400 uppercase tracking-widest">Custom</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="pt-8 mt-auto border-t border-gray-100 flex justify-between items-center pb-10">
                    <button type="button" data-prev="5" class="prev-step-btn text-gray-400 font-bold hover:text-indigo-600 transition-all">&laquo; Back</button>
                    <button type="button" id="final-save-btn" class="bg-indigo-600 text-white px-12 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Finish & Save</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Right Content: Live Preview -->
    <div id="preview-section" class="hidden lg:flex flex-grow h-full bg-gray-100 flex-col items-center pt-12 pb-24 overflow-y-auto transition-all duration-500">
        <!-- Preview Container -->
        <div id="preview-frame" class="bg-white w-full max-w-[794px] shadow-2xl rounded shadow-gray-200 transform origin-top scale-[0.75] xl:scale-90 p-0 m-0">
            <!-- This will be replaced by the template HTML -->
            <div id="preview-content" class="w-full h-auto">
                Loading preview...
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
    const CV_ID = "<%= cv.id %>";
    const TEMPLATE_ID = "<%= cv.templateId %>";
    let cvData = <%- JSON.stringify(cvData) %>;
</script>
<script src="/js/editor.js"></script>
