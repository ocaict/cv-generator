<style>
    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .accordion-header svg { transition: transform 0.3s ease; }
    .quill-content p, #preview-content p { margin-bottom: 0.5rem; }
    .quill-content p:last-child, #preview-content p:last-child { margin-bottom: 0; }
    .quill-content ul, #preview-content ul { list-style-type: disc; padding-left: 1.25rem; margin-bottom: 0.5rem; }
    
    /* Restore layout elements but keep sidebar scrolling clean */
    footer { display: none !important; }
    main { padding-top: 0 !important; padding-bottom: 0 !important; }
    #preview-section { scroll-behavior: smooth; }
    
    .ai-success-flash {
        animation: ai-flash 2s ease-out;
        position: relative;
    }
    @keyframes ai-flash {
        0% { outline: 0px solid transparent; box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
        20% { outline: 3px solid rgba(74, 222, 128, 0.5); box-shadow: 0 0 0 8px rgba(74, 222, 128, 0.2); }
        100% { outline: 0px solid transparent; box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
    }
</style>
<link id="google-fonts-link" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Inter:wght@400;500;600&family=EB+Garamond:wght@400;600;700&display=swap" rel="stylesheet">
<div class="h-[calc(100vh-64px)] flex flex-col lg:flex-row overflow-hidden bg-gray-50 dark:bg-slate-950 uppercase-tracking-widest transition-colors duration-300">
    <!-- Left Sidebar: Controls -->
    <div id="sidebar" class="w-full lg:w-1/3 lg:min-w-[450px] h-full overflow-y-auto bg-white dark:bg-slate-900 border-r border-gray-100 dark:border-slate-800 flex flex-col p-6 lg:p-10 pb-32 transition-colors duration-300">
         <div class="flex flex-col mb-8 space-y-3">
            <!-- CV Title row -->
            <h1 class="text-2xl font-bold font-outfit text-gray-900 dark:text-white truncate"><%=  cv.title %></h1>
            <!-- Action buttons row -->
            <div class="flex items-center space-x-2 flex-wrap gap-y-2">
                <button id="save-btn" class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 text-gray-600 dark:text-slate-300 px-4 py-2 rounded-xl text-xs font-bold shadow-sm hover:shadow-md hover:bg-gray-50 dark:hover:bg-slate-700 transition-all flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 1l-3 3m0 0l-3-3m3 3V3"></path></svg>
                    <span>Save</span>
                </button>
                <button id="export-btn" class="bg-indigo-600 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-lg shadow-indigo-100 dark:shadow-none hover:bg-indigo-700 transition-all flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span>PDF</span>
                </button>
                <button id="export-docx-btn" class="bg-sky-600 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-lg shadow-sky-100 dark:shadow-none hover:bg-sky-700 transition-all flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                    <span>Word</span>
                </button>
                <button id="share-btn" data-public="<%= cv.isPublic %>" data-slug="<%= cv.publicSlug || '' %>" class="<%= cv.isPublic ? 'bg-green-600 shadow-green-100 hover:bg-green-700' : 'bg-violet-600 shadow-violet-100 hover:bg-violet-700' %> text-white px-4 py-2 rounded-xl text-xs font-bold shadow-lg transition-all flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
                    <span><%= cv.isPublic ? 'Shared' : 'Share' %></span>
                </button>
                <button id="ats-scan-btn" class="bg-amber-500 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-lg shadow-amber-100 dark:shadow-none hover:bg-amber-600 transition-all flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                    <span>ATS Score</span>
                </button>
                <button id="cover-letter-btn" class="bg-rose-500 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-lg shadow-rose-100 dark:shadow-none hover:bg-rose-600 transition-all flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    <span>Cover Letter</span>
                </button>
                <button id="cv-review-btn" class="bg-emerald-500 text-white px-4 py-2 rounded-xl text-xs font-bold shadow-lg shadow-emerald-100 dark:shadow-none hover:bg-emerald-600 transition-all flex items-center space-x-2">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>Review CV</span>
                </button>
            </div>
            <!-- Status & QR row -->
            <div class="flex items-center space-x-4">
                <div class="flex items-center space-x-2 text-[10px] text-gray-400 font-bold uppercase tracking-widest" id="save-status">
                    <div class="w-1.5 h-1.5 rounded-full bg-green-500" id="save-status-indicator"></div>
                    <span id="save-status-text">Saved</span>
                </div>
                <!-- QR Code toggle panel (shown only when CV is public) -->
                <div id="qr-toggle-panel" class="<%= cv.isPublic ? '' : 'hidden' %> flex items-center space-x-2">
                    <label class="flex items-center space-x-2 cursor-pointer group">
                        <input type="checkbox" id="show-qr-toggle" class="w-3.5 h-3.5 rounded border-gray-300 text-violet-600 focus:ring-violet-500" <%= cvData.showQrCode ? 'checked' : '' %>>
                        <span class="text-[10px] font-bold text-gray-400 group-hover:text-violet-600 uppercase tracking-widest transition-colors">QR on CV</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- Stepper -->
        <div class="flex items-center justify-between mb-10 px-2 bg-gray-50/50 dark:bg-slate-800/50 p-4 rounded-2xl border border-gray-100/50 dark:border-slate-700/50">
            <button type="button" class="step-btn active group" data-step="1">
                <div class="w-8 h-8 rounded-lg bg-indigo-600 text-white flex items-center justify-center font-bold text-xs shadow-lg shadow-indigo-100 dark:shadow-none transition-all group-hover:scale-110">1</div>
                <span class="text-[9px] font-bold text-indigo-600 dark:text-indigo-400 mt-2 block uppercase tracking-widest text-center">Info</span>
            </button>
            <div class="h-px w-3 bg-gray-200 dark:bg-slate-700 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="2">
                <div class="w-8 h-8 rounded-lg bg-white dark:bg-slate-800 border-2 border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 dark:group-hover:border-indigo-500 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">2</div>
            <span class="text-[9px] font-bold text-gray-400 dark:text-slate-500 mt-2 block uppercase tracking-widest text-center">Work</span>
            </button>
            <div class="h-px w-3 bg-gray-200 dark:bg-slate-700 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="3">
                <div class="w-8 h-8 rounded-lg bg-white dark:bg-slate-800 border-2 border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 dark:group-hover:border-indigo-500 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">3</div>
                <span class="text-[9px] font-bold text-gray-400 dark:text-slate-500 mt-2 block uppercase tracking-widest text-center">Edu</span>
            </button>
            <div class="h-px w-3 bg-gray-200 dark:bg-slate-700 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="4">
                <div class="w-8 h-8 rounded-lg bg-white dark:bg-slate-800 border-2 border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 dark:group-hover:border-indigo-500 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">4</div>
                <span class="text-[9px] font-bold text-gray-400 dark:text-slate-500 mt-2 block uppercase tracking-widest text-center">Skills</span>
            </button>
            <div class="h-px w-3 bg-gray-200 dark:bg-slate-700 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="5">
                <div class="w-8 h-8 rounded-lg bg-white dark:bg-slate-800 border-2 border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 dark:group-hover:border-indigo-500 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">5</div>
                <span class="text-[9px] font-bold text-gray-400 dark:text-slate-500 mt-2 block uppercase tracking-widest text-center">More</span>
            </button>
            <div class="h-px w-3 bg-gray-200 dark:bg-slate-700 -mt-6"></div>
            <button type="button" class="step-btn group" data-step="6">
                <div class="w-8 h-8 rounded-lg bg-white dark:bg-slate-800 border-2 border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-400 flex items-center justify-center font-bold text-xs transition-all group-hover:border-indigo-600 dark:group-hover:border-indigo-500 group-hover:text-indigo-600 dark:group-hover:text-indigo-400">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-3"></path></svg>
                </div>
                <span class="text-[9px] font-bold text-gray-400 dark:text-slate-500 mt-2 block uppercase tracking-widest text-center">Design</span>
            </button>
        </div>

        <form id="editor-form" class="flex-grow flex flex-col">
            <!-- Step 1: Personal Info -->
            <div id="step-form-1" class="step-form animate-fade-in space-y-12">
                <section>
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="flex items-center space-x-2 text-sm font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            <span>Personal Details</span>
                        </h3>
                    </div>

                    <!-- Profile Photo -->
                    <div class="flex items-center space-x-6 mb-10 p-6 bg-indigo-50/30 dark:bg-slate-800/50 rounded-3xl border border-indigo-100/50 dark:border-slate-700/50 group transition-all hover:bg-indigo-50/50 dark:hover:bg-slate-800">
                        <div class="relative">
                            <div id="photo-preview" class="w-24 h-24 rounded-2xl bg-white dark:bg-slate-900 border-2 border-dashed border-indigo-200 dark:border-slate-600 flex items-center justify-center overflow-hidden shadow-inner group-hover:border-indigo-400 dark:group-hover:border-indigo-500 transition-all">
                                <% if (cvData.personalInfo && cvData.personalInfo.photo) { %>
                                    <img src="<%= cvData.personalInfo.photo %>" class="w-full h-full object-cover">
                                <% } else { %>
                                    <svg class="w-8 h-8 text-indigo-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                <% } %>
                            </div>
                            <button type="button" id="remove-photo" class="<%= (cvData.personalInfo && cvData.personalInfo.photo) ? '' : 'hidden' %> absolute -top-2 -right-2 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center shadow-lg hover:bg-red-600 transition-all text-xs font-bold">×</button>
                        </div>
                        <div class="flex-grow">
                            <h4 class="text-xs font-bold text-gray-900 dark:text-gray-100 mb-1">Profile Photo</h4>
                            <p class="text-[10px] text-gray-400 dark:text-slate-500 font-medium mb-3">Upload a professional photo (JPG, PNG). Max 2MB.</p>
                            <input type="file" id="photo-input" accept="image/*" class="hidden">
                            <button type="button" onclick="document.getElementById('photo-input').click()" class="bg-white dark:bg-slate-800 border border-indigo-200 dark:border-slate-600 text-indigo-600 dark:text-indigo-400 px-4 py-2 rounded-xl text-[10px] font-bold shadow-sm hover:border-indigo-400 hover:text-indigo-700 dark:hover:border-indigo-500 dark:hover:text-indigo-300 transition-all uppercase tracking-widest">Select Image</button>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">First Name</label>
                            <input type="text" name="personalInfo.firstName" value="<%= cvData.personalInfo.firstName || '' %>" placeholder="e.g. John" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">Last Name</label>
                            <input type="text" name="personalInfo.lastName" value="<%= cvData.personalInfo.lastName || '' %>" placeholder="e.g. Doe" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">Job Title</label>
                            <input type="text" name="personalInfo.jobTitle" value="<%= cvData.personalInfo.jobTitle %>" placeholder="e.g. Sales Manager" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">Email Address</label>
                            <input type="email" name="personalInfo.email" value="<%= cvData.personalInfo.email || '' %>" placeholder="e.g. john@example.com" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">Phone Number</label>
                            <input type="tel" name="personalInfo.phone" value="<%= cvData.personalInfo.phone || '' %>" placeholder="e.g. +1 234..." class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">Address</label>
                            <input type="text" name="personalInfo.address" value="<%= cvData.personalInfo.address || '' %>" placeholder="e.g. 123 Main St" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                        </div>
                        <div class="col-span-2 grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">Zip Code</label>
                                <input type="text" name="personalInfo.zipCode" value="<%= cvData.personalInfo.zipCode || '' %>" placeholder="e.g. 123456" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">City/Town</label>
                                <input type="text" name="personalInfo.city" value="<%= cvData.personalInfo.city || '' %>" placeholder="e.g. London" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white transition-all outline-none">
                            </div>
                        <div class="col-span-2 pt-4">
                            <label class="block text-[10px] font-bold text-gray-400 dark:text-slate-500 mb-2 uppercase tracking-widest">Global AI Writing Tone</label>
                            <select name="aiTone" id="ai-tone-selector" class="w-full px-4 py-3 bg-indigo-50 dark:bg-slate-800 border border-indigo-100 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 text-xs font-bold text-indigo-700 dark:text-indigo-400 outline-none cursor-pointer transition-all hover:bg-indigo-100/50 dark:hover:bg-slate-700/80">
                                <optgroup label="General Tones">
                                    <option value="Professional" <%= (cvData.aiTone === 'Professional') ? 'selected' : '' %>>🤝 Professional (Balanced & Standard)</option>
                                    <option value="Executive" <%= (cvData.aiTone === 'Executive') ? 'selected' : '' %>>💼 Executive (Strong & Authoritative)</option>
                                    <option value="Creative" <%= (cvData.aiTone === 'Creative') ? 'selected' : '' %>>🎨 Creative (Personal & Narrative)</option>
                                    <option value="Concise" <%= (cvData.aiTone === 'Concise') ? 'selected' : '' %>>⚡ Concise (Sharp & Bullet-focused)</option>
                                </optgroup>
                                <optgroup label="Industry Specific">
                                    <option value="Tech/Startup" <%= (cvData.aiTone === 'Tech/Startup') ? 'selected' : '' %>>🚀 Tech/Startup (Metric-driven & Agile)</option>
                                    <option value="Law/Finance" <%= (cvData.aiTone === 'Law/Finance') ? 'selected' : '' %>>🏛️ Law/Finance (Formal, Precise & Compliant)</option>
                                    <option value="Healthcare" <%= (cvData.aiTone === 'Healthcare') ? 'selected' : '' %>>⚕️ Healthcare (Clinical, Empathetic & Regulated)</option>
                                    <option value="Academic" <%= (cvData.aiTone === 'Academic') ? 'selected' : '' %>>🎓 Academic (Thorough, Research-focused)</option>
                                </optgroup>
                            </select>
                        </div>

                        <!-- Additional Info Toggle -->
                        <div class="col-span-2 pt-4">
                            <button type="button" id="toggle-additional-info" class="w-full py-4 border-y border-gray-100 dark:border-slate-800 flex items-center justify-center space-x-2 text-indigo-600 dark:text-indigo-400 font-bold text-xs uppercase tracking-widest hover:bg-gray-50 dark:hover:bg-slate-800/50 transition-all">
                                <span id="toggle-icon">+</span>
                                <span>Additional Information</span>
                            </button>
                        </div>

                        <div id="additional-info-panel" class="col-span-2 grid grid-cols-2 gap-4 hidden py-4 animate-fade-in text-left">
                            <div class="col-span-2 sm:col-span-1">
                                <label class="block text-xs font-bold text-gray-500 dark:text-slate-400 mb-2 uppercase">Date of Birth</label>
                                <div class="grid grid-cols-3 gap-2">
                                    <select name="personalInfo.dobDay" class="w-full px-3 py-2 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white text-[10px] outline-none">
                                        <option value="">Day</option>
                                        <% for(let i=1; i<=31; i++) { %>
                                            <option value="<%= i %>" <%= (cvData.personalInfo.dobDay == i) ? 'selected' : '' %>><%= i %></option>
                                        <% } %>
                                    </select>
                                    <select name="personalInfo.dobMonth" class="w-full px-3 py-2 bg-gray-50 dark:bg-slate-800/50 border border-gray-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500 dark:text-white text-[10px] outline-none">
                                        <option value="">Month</option>
                                        <% ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"].forEach(m => { %>
                                            <option value="<%= m %>" <%= (cvData.personalInfo.dobMonth == m) ? 'selected' : '' %>><%= m %></option>
                                        <% }) %>
                                    </select>
