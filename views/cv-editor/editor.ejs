                                                <div class="w-2/3 h-full bg-gray-50 rounded-lg flex flex-col space-y-2 p-2">
                                                    <div class="h-2 w-full bg-gray-300 rounded-full"></div>
                                                    <div class="h-full w-full bg-gray-100 rounded-lg"></div>
                                                </div>
                                            </div>
                                        </div>
                                        <h5 class="text-xs font-black text-gray-900 mb-1 uppercase tracking-tight">The Gridsmith</h5>
                                        <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest leading-none">Tech • Multi-column</p>
                                    </div>
                                </label>

                                <label class="cursor-pointer group col-span-2 sm:col-span-1">
                                    <input type="radio" name="templateId" value="onyx" class="hidden peer" <%= cv.templateId === 'onyx' ? 'checked' : '' %>>
                                    <div class="p-4 border-2 border-slate-800 bg-slate-900 rounded-3xl group-hover:border-indigo-400 peer-checked:border-indigo-500 peer-checked:bg-slate-900 peer-checked:shadow-xl peer-checked:shadow-indigo-900/50 transition-all text-left">
                                        <div class="aspect-[4/3] bg-slate-800 rounded-2xl mb-4 overflow-hidden flex flex-col items-center justify-center space-y-2 border border-slate-700 group-hover:bg-slate-700 transition-colors">
                                            <div class="w-16 h-2 bg-indigo-500 rounded-full"></div>
                                            <div class="w-20 h-1 bg-slate-600 rounded-full"></div>
                                            <div class="w-20 h-1 bg-slate-600 rounded-full"></div>
                                            <div class="w-20 h-1 bg-slate-600 rounded-full"></div>
                                        </div>
                                        <h5 class="text-xs font-black text-white mb-1 uppercase tracking-tight">Onyx Dark</h5>
                                        <p class="text-[9px] text-indigo-400 font-bold uppercase tracking-widest leading-none">Premium • High Contrast</p>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <label class="block text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-widest leading-none">Typography Style</label>
                                <select name="fontPairing" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 text-xs font-bold text-gray-700 outline-none focus:border-indigo-600 transition-all appearance-none">
                                    <option value="outfit-inter" <%= cv.fontPairing === 'outfit-inter' ? 'selected' : '' %>>Modern (Outfit + Inter)</option>
                                    <option value="serif-inter" <%= cv.fontPairing === 'serif-inter' ? 'selected' : '' %>>Professional (Serif + Inter)</option>
                                    <option value="inter-inter" <%= cv.fontPairing === 'inter-inter' ? 'selected' : '' %>>Standard (Inter + Inter)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-gray-400 mb-2 uppercase tracking-widest leading-none">Content Density</label>
                                <select name="density" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 text-xs font-bold text-gray-700 outline-none focus:border-indigo-600 transition-all appearance-none">
                                    <option value="tight" <%= cv.density === 'tight' ? 'selected' : '' %>>Compact</option>
                                    <option value="standard" <%= cv.density === 'standard' ? 'selected' : '' %>>Standard</option>
                                    <option value="airy" <%= cv.density === 'airy' ? 'selected' : '' %>>Airy (Premium)</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 mb-4 uppercase tracking-widest leading-none">Primary Accent Color</label>
                            <div class="flex flex-wrap gap-4 items-center">
                                <% const colors = [
                                    { name: 'Indigo', hex: '#4f46e5' },
                                    { name: 'Sky', hex: '#0ea5e9' },
                                    { name: 'Emerald', hex: '#10b981' },
                                    { name: 'Amber', hex: '#f59e0b' },
                                    { name: 'Rose', hex: '#f43f5e' },
                                    { name: 'Slate', hex: '#475569' }
                                ] %>
                                <% colors.forEach(color => { %>
                                    <label class="relative cursor-pointer group">
                                        <input type="radio" name="themeColor" value="<%= color.hex %>" class="hidden peer" <%= (cvData.themeColor || '#4f46e5') === color.hex ? 'checked' : '' %>>
                                        <div class="w-10 h-10 rounded-xl border-2 border-white ring-2 ring-transparent peer-checked:ring-indigo-600 peer-checked:scale-110 shadow-sm transition-all group-hover:scale-105" style="background-color: <%= color.hex %>;"></div>
                                    </label>
                                <% }) %>
                                <div class="flex flex-col items-center space-y-2 ml-2">
                                    <input type="color" name="themeColorCustom" id="custom-color-picker" class="w-10 h-10 rounded-xl border-2 border-gray-100 p-1 cursor-pointer bg-white shadow-sm" value="<%= cvData.themeColor || '#4f46e5' %>">
                                    <span class="text-[8px] font-bold text-gray-400 uppercase tracking-widest">Custom</span>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-6 mt-8 pt-8 border-t border-gray-100">
                            <div>
                                <label class="block text-[10px] font-bold text-gray-400 mb-3 uppercase tracking-widest leading-none">Sidebar Position</label>
                                <div class="flex p-1 bg-gray-50 rounded-xl space-x-1">
                                    <label class="flex-1 cursor-pointer">
                                        <input type="radio" name="sidebarPos" value="left" class="hidden peer" <%= (cvData.sidebarPos || 'left') === 'left' ? 'checked' : '' %>>
                                        <div class="py-2 text-center text-[10px] font-bold text-gray-400 peer-checked:bg-white peer-checked:text-indigo-600 peer-checked:shadow-sm rounded-lg transition-all">LEFT</div>
                                    </label>
                                    <label class="flex-1 cursor-pointer">
                                        <input type="radio" name="sidebarPos" value="right" class="hidden peer" <%= (cvData.sidebarPos || 'left') === 'right' ? 'checked' : '' %>>
                                        <div class="py-2 text-center text-[10px] font-bold text-gray-400 peer-checked:bg-white peer-checked:text-indigo-600 peer-checked:shadow-sm rounded-lg transition-all">RIGHT</div>
                                    </label>
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-gray-400 mb-3 uppercase tracking-widest leading-none">Section Style</label>
                                <select name="sidebarStyle" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2.5 text-[10px] font-bold text-gray-700 outline-none focus:border-indigo-600 transition-all appearance-none uppercase tracking-widest">
                                    <option value="minimal" <%= (cvData.sidebarStyle || 'minimal') === 'minimal' ? 'selected' : '' %>>Minimal Text</option>
                                    <option value="underline" <%= (cvData.sidebarStyle || 'minimal') === 'underline' ? 'selected' : '' %>>Underlined</option>
                                    <option value="pill" <%= (cvData.sidebarStyle || 'minimal') === 'pill' ? 'selected' : '' %>>Accent Pill</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-8">
                             <label class="block text-[10px] font-bold text-gray-400 mb-3 uppercase tracking-widest leading-none">Photo Display Style</label>
                             <div class="flex space-x-4">
                                <% const photoStylesList = ['square', 'rounded', 'circle', 'hidden'] %>
                                <% photoStylesList.forEach(style => { %>
                                    <label class="cursor-pointer group flex-1">
                                         <input type="radio" name="photoStyle" value="<%= style %>" class="hidden peer" <%= (cvData.photoStyle || 'rounded') === style ? 'checked' : '' %>>
                                         <div class="py-3 px-2 border-2 border-gray-100 rounded-xl text-center group-hover:border-indigo-200 peer-checked:border-indigo-600 peer-checked:bg-indigo-50 transition-all">
                                             <div class="w-8 h-8 bg-gray-200 mx-auto mb-1 
                                                <%= style === 'circle' ? 'rounded-full' : (style === 'rounded' ? 'rounded-lg' : 'rounded-none') %>
                                                <%= style === 'hidden' ? 'opacity-20' : '' %>">
                                                <% if (style === 'hidden') { %>
                                                    <div class="w-full h-full flex items-center justify-center text-[8px] text-gray-400">∅</div>
                                                <% } %>
                                             </div>
                                             <span class="text-[8px] font-bold text-gray-400 uppercase tracking-widest leading-none text-center block"><%= style %></span>
                                         </div>
                                    </label>
                                <% }) %>
                             </div>
                        </div>

                        <div class="mt-8">
                             <label class="block text-[10px] font-bold text-gray-400 mb-3 uppercase tracking-widest leading-none">Section Labels</label>
                             <div class="flex p-1 bg-gray-50 rounded-xl space-x-1 w-full max-w-xs">
                                 <label class="flex-1 cursor-pointer">
                                     <input type="radio" name="showHeaderIcons" value="text" class="hidden peer" <%= (cvData.showHeaderIcons || 'text') === 'text' ? 'checked' : '' %>>
                                     <div class="py-2 text-center text-[10px] font-bold text-gray-400 peer-checked:bg-white peer-checked:text-indigo-600 peer-checked:shadow-sm rounded-lg transition-all uppercase tracking-widest">Text Only</div>
                                 </label>
                                 <label class="flex-1 cursor-pointer">
                                     <input type="radio" name="showHeaderIcons" value="icons" class="hidden peer" <%= (cvData.showHeaderIcons || 'text') === 'icons' ? 'checked' : '' %>>
                                     <div class="py-2 text-center text-[10px] font-bold text-gray-400 peer-checked:bg-white peer-checked:text-indigo-600 peer-checked:shadow-sm rounded-lg transition-all uppercase tracking-widest">With Icons</div>
                                 </label>
                             </div>
                        </div>

                        <div class="mt-8">
                             <label class="block text-[10px] font-bold text-gray-400 mb-3 uppercase tracking-widest leading-none">Section Visibility</label>
                             <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                                 <% const visSections = [{id: 'profile', name: 'Summary'}, {id: 'experience', name: 'Experience'}, {id: 'education', name: 'Education'}, {id: 'skills', name: 'Skills'}, {id: 'interests', name: 'Interests'}, {id: 'references', name: 'References'}]; %>
                                 <% visSections.forEach(sec => { %>
                                     <label class="flex items-center p-3 bg-white border border-gray-100 rounded-xl cursor-pointer hover:border-indigo-200 hover:bg-indigo-50/10 transition-all select-none group">
                                         <input type="checkbox" name="sectionVisibility.<%= sec.id %>" class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 mr-3 transition-all" <%= (!cvData.sectionVisibility || cvData.sectionVisibility[sec.id] !== false) ? 'checked' : '' %>>
                                         <span class="text-[10px] font-bold text-gray-600 group-hover:text-indigo-600 uppercase tracking-widest"><%= sec.name %></span>
                                     </label>
                                 <% }) %>
                             </div>
                        </div>

                        <div id="layout-config-area" class="pt-6 border-t border-gray-100 mt-6">
                            <label class="block text-[10px] font-bold text-gray-400 mb-6 uppercase tracking-widest leading-none">Layout & Section Order (Drag to Reorder)</label>
                            
                            <div id="reorder-zone-container" class="grid grid-cols-2 gap-8">
                                <div>
                                    <label id="main-column-label" class="block text-[9px] font-bold text-gray-300 mb-3 uppercase tracking-wider">Main Column</label>
                                    <div id="main-sections-list" class="space-y-2 p-3 bg-gray-50/50 rounded-2xl border-2 border-dashed border-gray-100 min-h-[100px]">
                                        <!-- Sections will be rendered here -->
                                    </div>
                                </div>
                                <div id="sidebar-column-zone">
                                    <label class="block text-[9px] font-bold text-gray-300 mb-3 uppercase tracking-wider text-right">Sidebar / Details</label>
                                    <div id="sidebar-sections-list" class="space-y-2 p-3 bg-gray-50/50 rounded-2xl border-2 border-dashed border-gray-100 min-h-[100px]">
                                        <!-- Sections will be rendered here -->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="pt-8 mt-auto border-t border-gray-100 flex justify-between items-center pb-10">
                    <button type="button" data-prev="5" class="prev-step-btn text-gray-400 font-bold hover:text-indigo-600 transition-all">&laquo; Back</button>
                    <button type="button" id="final-save-btn" class="bg-indigo-600 text-white px-12 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Finish & Save</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Right Content: Live Preview -->
    <div id="preview-section" class="hidden lg:flex flex-grow h-full bg-gray-100 flex-col items-center pt-12 pb-24 overflow-y-auto transition-all duration-500">
        <!-- Preview Container -->
        <div id="preview-frame" class="bg-white w-full max-w-[794px] shadow-2xl rounded shadow-gray-200 transform origin-top scale-[0.75] xl:scale-90 p-0 m-0">
            <!-- This will be replaced by the template HTML -->
            <div id="preview-content" class="w-full h-auto">
                Loading preview...
            </div>
        </div>
    </div>
</div>

<!-- ============================================================ -->
<!-- CV Review Modal                                             -->
<!-- ============================================================ -->
<div id="review-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="review-backdrop" class="absolute inset-0 bg-slate-900/70 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-2xl bg-white dark:bg-slate-900 rounded-3xl shadow-2xl overflow-hidden flex flex-col" style="max-height:92vh;">
        <!-- Header -->
        <div class="flex items-center justify-between px-8 py-5 border-b border-gray-100 dark:border-slate-800 bg-gradient-to-r from-emerald-50 to-teal-50 dark:from-slate-800 dark:to-slate-800">
            <div>
                <h2 class="text-lg font-extrabold text-gray-900 dark:text-white font-outfit">🧠 CV Review</h2>
                <p class="text-xs text-gray-400 dark:text-slate-400 mt-0.5">AI-powered professional assessment of your entire CV</p>
            </div>
            <button id="review-close-btn" class="w-8 h-8 rounded-xl bg-white dark:bg-slate-700 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-all flex items-center justify-center shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto px-8 py-6 space-y-6">
            <!-- Loading -->
            <div id="review-loading" class="flex flex-col items-center justify-center py-16 space-y-4">
                <svg class="w-12 h-12 animate-spin text-emerald-400" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                <p class="text-sm font-bold text-gray-400 animate-pulse">Analysing your CV...</p>
            </div>

            <!-- Results -->
            <div id="review-results" class="hidden space-y-6">
                <!-- Score + Level -->
                <div class="flex items-center space-x-8">
                    <div class="relative w-32 h-32 flex-shrink-0">
                        <svg class="w-full h-full -rotate-90" viewBox="0 0 120 120">
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#f0fdf4" stroke-width="10"/>
                            <circle id="review-score-ring" cx="60" cy="60" r="50" fill="none" stroke="#10b981" stroke-width="10"
                                stroke-linecap="round" stroke-dasharray="314" stroke-dashoffset="314"
                                style="transition: stroke-dashoffset 1.2s ease-in-out;"/>
                        </svg>
                        <div class="absolute inset-0 flex flex-col items-center justify-center">
                            <span id="review-score-value" class="text-4xl font-extrabold text-gray-900 dark:text-white">0</span>
                            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">/ 100</span>
                        </div>
                    </div>
                    <div class="flex-1">
                        <p id="review-level-badge" class="inline-block text-xs font-black uppercase tracking-widest px-3 py-1 rounded-full mb-2"></p>
                        <p id="review-verdict" class="text-sm text-gray-600 dark:text-slate-300 leading-relaxed"></p>
                    </div>
                </div>

                <!-- Strengths -->
                <div>
                    <h3 class="text-[10px] font-black text-emerald-600 uppercase tracking-widest mb-3 flex items-center space-x-1.5">
                        <span>✅</span><span>3 Strengths</span>
                    </h3>
                    <div id="review-strengths" class="space-y-2"></div>
                </div>

                <!-- Weaknesses -->
                <div>
                    <h3 class="text-[10px] font-black text-red-500 uppercase tracking-widest mb-3 flex items-center space-x-1.5">
                        <span>⚠️</span><span>3 Areas to Improve</span>
                    </h3>
                    <div id="review-weaknesses" class="space-y-2"></div>
                </div>

                <!-- Action Items -->
                <div class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-700 rounded-2xl p-5">
                    <h3 class="text-[10px] font-black text-emerald-700 dark:text-emerald-400 uppercase tracking-widest mb-3 flex items-center space-x-1.5">
                        <span>💡</span><span>Top 3 Actions to Take Now</span>
                    </h3>
                    <div id="review-actions" class="space-y-2.5"></div>
                </div>

                <!-- Re-review button -->
                <button id="review-rerun-btn" class="w-full border-2 border-emerald-400 text-emerald-600 dark:text-emerald-400 font-bold text-xs py-3 rounded-2xl hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-all">
                    ↺ Run Review Again
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================ -->
<!-- Cover Letter Modal                                          -->
<!-- ============================================================ -->
<div id="cl-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div id="cl-backdrop" class="absolute inset-0 bg-slate-900/70 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-3xl bg-white dark:bg-slate-900 rounded-3xl shadow-2xl overflow-hidden flex flex-col" style="max-height:92vh;">
        <!-- Header -->
        <div class="flex items-center justify-between px-8 py-5 border-b border-gray-100 dark:border-slate-800 bg-gradient-to-r from-rose-50 to-pink-50 dark:from-slate-800 dark:to-slate-800">
            <div>
                <h2 class="text-lg font-extrabold text-gray-900 dark:text-white font-outfit">✉️ Cover Letter Generator</h2>
                <p class="text-xs text-gray-400 dark:text-slate-400 mt-0.5">AI-powered cover letters tailored to the job</p>
            </div>
            <button id="cl-close-btn" class="w-8 h-8 rounded-xl bg-white dark:bg-slate-700 text-gray-400 hover:bg-red-50 hover:text-red-500 transition-all flex items-center justify-center shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto">
            <!-- Step 1: Inputs -->
            <div id="cl-input-section" class="px-8 py-6 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Company Name</label>
                        <input id="cl-company" type="text" placeholder="e.g. Google" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-xs text-gray-700 dark:text-slate-300 focus:ring-2 focus:ring-rose-400 outline-none">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Hiring Manager <span class="text-gray-300">(optional)</span></label>
                        <input id="cl-manager" type="text" placeholder="e.g. Sarah Johnson" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-xs text-gray-700 dark:text-slate-300 focus:ring-2 focus:ring-rose-400 outline-none">
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Job Title Applying For</label>
                    <input id="cl-job-title" type="text" placeholder="e.g. Senior Product Designer" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-xs text-gray-700 dark:text-slate-300 focus:ring-2 focus:ring-rose-400 outline-none">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">Job Description <span class="text-gray-300">(paste for best results)</span></label>
                    <textarea id="cl-job-desc" rows="5" placeholder="Paste the job description here — the AI uses it to tailor your letter to the specific requirements..." class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl text-xs text-gray-700 dark:text-slate-300 leading-relaxed focus:ring-2 focus:ring-rose-400 outline-none resize-none"></textarea>
                </div>
                <button id="cl-generate-btn" class="w-full bg-rose-500 hover:bg-rose-600 text-white font-bold text-sm py-3.5 rounded-2xl transition-all shadow-lg shadow-rose-100 dark:shadow-none flex items-center justify-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <span>Generate Cover Letter</span>
                </button>
            </div>

            <!-- Loading -->
            <div id="cl-loading" class="hidden flex flex-col items-center justify-center py-16 space-y-4">
                <svg class="w-12 h-12 animate-spin text-rose-400" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                <p class="text-sm font-bold text-gray-400 animate-pulse">Writing your cover letter...</p>
            </div>

            <!-- Result / Editor -->
            <div id="cl-result-section" class="hidden px-8 py-6 space-y-4">
                <!-- Letter meta preview -->
                <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl px-5 py-4 border border-gray-100 dark:border-slate-700">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Prepared for</p>
                            <p id="cl-meta-role" class="text-sm font-bold text-gray-800 dark:text-white mt-0.5"></p>
                        </div>
                        <div class="text-right">
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Company</p>
                            <p id="cl-meta-company" class="text-sm font-bold text-rose-500 mt-0.5"></p>
                        </div>
                    </div>
                </div>

                <!-- Editable letter textarea -->
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Your Cover Letter <span class="text-gray-300 normal-case font-normal">(editable)</span></label>
                        <button id="cl-regenerate-btn" class="text-[9px] font-bold text-rose-500 hover:text-rose-600 uppercase tracking-widest flex items-center space-x-1 transition-colors">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                            <span>Regenerate</span>
                        </button>
                    </div>
                    <textarea id="cl-letter-text" rows="16" class="w-full px-5 py-4 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl text-xs text-gray-700 dark:text-slate-300 leading-relaxed focus:ring-2 focus:ring-rose-400 outline-none resize-none font-mono"></textarea>
                </div>

                <!-- Export buttons -->
                <div class="flex items-center space-x-3">
                    <button id="cl-export-pdf-btn" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs py-3 rounded-2xl transition-all shadow-lg shadow-indigo-100 dark:shadow-none flex items-center justify-center space-x-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        <span>Download PDF</span>
                    </button>
                    <button id="cl-export-docx-btn" class="flex-1 bg-sky-600 hover:bg-sky-700 text-white font-bold text-xs py-3 rounded-2xl transition-all shadow-lg shadow-sky-100 dark:shadow-none flex items-center justify-center space-x-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                        <span>Download Word</span>
                    </button>
                    <button id="cl-copy-btn" class="px-4 py-3 bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-slate-300 font-bold text-xs rounded-2xl hover:bg-gray-200 dark:hover:bg-slate-600 transition-all" title="Copy to clipboard">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================ -->
<!-- ATS Score Modal                                             -->
<!-- ============================================================ -->
<div id="ats-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div id="ats-backdrop" class="absolute inset-0 bg-slate-900/70 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative w-full max-w-2xl bg-white dark:bg-slate-900 rounded-3xl shadow-2xl overflow-hidden flex flex-col" style="max-height: 90vh;">
        <!-- Header -->
        <div class="flex items-center justify-between px-8 py-6 border-b border-gray-100 dark:border-slate-800">
            <div>
                <h2 class="text-lg font-extrabold text-gray-900 dark:text-white font-outfit">ATS Score Checker</h2>
                <p class="text-xs text-gray-400 dark:text-slate-400 mt-0.5">Paste a job description to see how well your CV matches it</p>
            </div>
            <button id="ats-close-btn" class="w-8 h-8 rounded-xl bg-gray-100 dark:bg-slate-800 text-gray-400 dark:text-slate-400 hover:bg-red-50 hover:text-red-500 transition-all flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <!-- Scrollable body -->
        <div class="flex-1 overflow-y-auto px-8 py-6 space-y-6">
            <!-- Job description input -->
            <div id="ats-input-section">
                <label class="block text-[10px] font-bold text-gray-400 dark:text-slate-400 uppercase tracking-widest mb-2">Paste Job Description</label>
                <textarea id="ats-job-description" rows="8" placeholder="Paste the full job description here — include requirements, responsibilities, and skills listed..." class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl text-xs text-gray-700 dark:text-slate-300 leading-relaxed focus:ring-2 focus:ring-amber-400 outline-none resize-none transition-all"></textarea>
                <button id="ats-run-btn" class="mt-3 w-full bg-amber-500 hover:bg-amber-600 text-white font-bold text-sm py-3 rounded-2xl transition-all shadow-lg shadow-amber-100 dark:shadow-none flex items-center justify-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    <span>Analyse My CV</span>
                </button>
            </div>

            <!-- Loading state -->
            <div id="ats-loading" class="hidden flex flex-col items-center justify-center py-12 space-y-4">
                <div class="relative w-16 h-16">
                    <svg class="w-16 h-16 animate-spin text-amber-400" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
                </div>
                <p class="text-sm font-bold text-gray-500 dark:text-slate-400 animate-pulse">Scanning your CV against the job...</p>
            </div>

            <!-- Results -->
            <div id="ats-results" class="hidden space-y-6">
                <!-- Score ring -->
                <div class="flex items-center justify-center">
                    <div class="relative w-36 h-36">
                        <svg class="w-full h-full -rotate-90" viewBox="0 0 120 120">
                            <circle cx="60" cy="60" r="50" fill="none" stroke="#f3f4f6" stroke-width="10"/>
                            <circle id="ats-score-ring" cx="60" cy="60" r="50" fill="none" stroke="#f59e0b" stroke-width="10"
                                stroke-linecap="round" stroke-dasharray="314" stroke-dashoffset="314"
                                style="transition: stroke-dashoffset 1.2s ease-in-out;"/>
                        </svg>
                        <div class="absolute inset-0 flex flex-col items-center justify-center">
                            <span id="ats-score-value" class="text-4xl font-extrabold text-gray-900 dark:text-white">0</span>
                            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">/ 100</span>
                        </div>
                    </div>
                </div>
                <p id="ats-score-label" class="text-center text-sm font-bold"></p>

                <!-- Matched keywords -->
                <div>
                    <label class="block text-[10px] font-bold text-green-600 uppercase tracking-widest mb-2">✅ Keywords Found in Your CV</label>
                    <div id="ats-matched-keywords" class="flex flex-wrap gap-2"></div>
                </div>

                <!-- Missing keywords -->
                <div>
                    <label class="block text-[10px] font-bold text-red-500 uppercase tracking-widest mb-2">❌ Keywords Missing from Your CV</label>
                    <div id="ats-missing-keywords" class="flex flex-wrap gap-2"></div>
                </div>

                <!-- Tip -->
                <div id="ats-tip-box" class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-2xl p-4">
                    <p class="text-[10px] font-bold text-amber-600 dark:text-amber-400 uppercase tracking-widest mb-1">💡 Top Recommendation</p>
                    <p id="ats-tip-text" class="text-xs text-amber-800 dark:text-amber-300 leading-relaxed"></p>
                </div>

                <!-- Re-scan button -->
                <button id="ats-rescan-btn" class="w-full border-2 border-amber-400 text-amber-600 dark:text-amber-400 font-bold text-xs py-3 rounded-2xl hover:bg-amber-50 dark:hover:bg-amber-900/20 transition-all">
                    ↩ Scan a Different Job Description
                </button>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    const CV_ID = "<%= cv.id %>";
    const TEMPLATE_ID = "<%= cv.templateId %>";
    let cvData = <%- JSON.stringify(cvData) %>;
</script>
<script src="/js/editor.js?v=<%= Date.now() %>"></script>
<script>
    // --- QR Code Toggle Logic ---
    const qrToggle = document.getElementById('show-qr-toggle');
    const qrPreviewMini = document.getElementById('qr-preview-mini');
    const qrTogglePanel = document.getElementById('qr-toggle-panel');
    let qrMiniInstance = null;

    function renderMiniQr(slug) {
        if (!slug || !qrPreviewMini) return;
        qrPreviewMini.innerHTML = '';
        qrMiniInstance = new QRCode(qrPreviewMini, {
            text: window.location.origin + '/p/' + slug,
            width: 32, height: 32,
            colorDark: '#1e293b', colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.M
        });
        qrPreviewMini.classList.remove('hidden');
    }

    if (qrToggle && qrToggle.checked) {
        const slug = document.getElementById('share-btn')?.dataset.slug;
        if (slug) renderMiniQr(slug);
    }

    if (qrToggle) {
        qrToggle.addEventListener('change', async () => {
            const enabled = qrToggle.checked;
            const slug = document.getElementById('share-btn')?.dataset.slug;
            cvData.showQrCode = enabled;
            updatePreview();
            if (enabled && slug) {
                renderMiniQr(slug);
            } else {
                if (qrPreviewMini) qrPreviewMini.classList.add('hidden');
            }
            autoSave();
        });
    }

    const shareBtnEl = document.getElementById('share-btn');
    if (shareBtnEl) {
        const observer = new MutationObserver(() => {
            const isShared = shareBtnEl.dataset.public === 'true';
            if (qrTogglePanel) {
                isShared ? qrTogglePanel.classList.remove('hidden') : qrTogglePanel.classList.add('hidden');
            }
        });
        observer.observe(shareBtnEl, { attributes: true, attributeFilter: ['data-public'] });
    }

    // ============================================================
    // ATS Score Modal Logic
    // ============================================================
    const atsModal       = document.getElementById('ats-modal');
    const atsBackdrop    = document.getElementById('ats-backdrop');
    const atsScanBtn     = document.getElementById('ats-scan-btn');
    const atsCloseBtn    = document.getElementById('ats-close-btn');
    const atsRunBtn      = document.getElementById('ats-run-btn');
    const atsRescanBtn   = document.getElementById('ats-rescan-btn');
    const atsJobDesc     = document.getElementById('ats-job-description');
    const atsLoading     = document.getElementById('ats-loading');
    const atsResults     = document.getElementById('ats-results');
    const atsInputSec    = document.getElementById('ats-input-section');
    const atsScoreRing   = document.getElementById('ats-score-ring');
    const atsScoreValue  = document.getElementById('ats-score-value');
    const atsScoreLabel  = document.getElementById('ats-score-label');
    const atsMatchedKW   = document.getElementById('ats-matched-keywords');
    const atsMissingKW   = document.getElementById('ats-missing-keywords');
    const atsTipText     = document.getElementById('ats-tip-text');

    function openAtsModal() {
        atsModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        atsResults.classList.add('hidden');
        atsLoading.classList.add('hidden');
        atsInputSec.classList.remove('hidden');
    }

    function closeAtsModal() {
        atsModal.classList.add('hidden');
        document.body.style.overflow = '';
    }

    function getScoreColor(score) {
        if (score >= 75) return { ring: '#22c55e', label: '🟢 Excellent Match — Your CV is well-optimised for this role!', labelClass: 'text-green-600' };
        if (score >= 50) return { ring: '#f59e0b', label: '🟡 Moderate Match — A few tweaks will make a big difference.', labelClass: 'text-amber-500' };
        return { ring: '#ef4444', label: '🔴 Low Match — Your CV needs keyword improvements for this role.', labelClass: 'text-red-500' };
    }

    async function runAtsScan() {
        const jobDesc = atsJobDesc.value.trim();
        if (jobDesc.length < 50) {
            alert('Please paste a more complete job description (at least a few sentences).');
            return;
        }

        // Build CV content summary for ATS comparison
        const cvText = [
            cvData.personalInfo?.summary || '',
            (cvData.experience || []).map(e => `${e.jobTitle} ${e.company} ${e.responsibilities || ''}`).join(' '),
            (cvData.skills?.technical || []).join(' '),
            (cvData.skills?.soft || []).join(' '),
            (cvData.education || []).map(e => `${e.degree} ${e.school} ${e.description || ''}`).join(' ')
        ].join(' ').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').slice(0, 3000);

        atsInputSec.classList.add('hidden');
        atsLoading.classList.remove('hidden');
        atsResults.classList.add('hidden');

        try {
            const res = await fetch('/api/ai/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'ats',
                    input: cvText,
                    context: { jobDescription: jobDesc }
                })
            });

            if (res.status === 429) {
                alert('Too many requests — please wait a moment before scanning again.');
                atsInputSec.classList.remove('hidden');
                atsLoading.classList.add('hidden');
                return;
            }

            const data = await res.json();
            if (!data.result) throw new Error('No result');

            // Parse structured response
            const scoreMatch   = data.result.match(/SCORE:\s*(\d+)/);
            const matchedMatch = data.result.match(/MATCHED:\s*([^\n]+)/);
            const missingMatch = data.result.match(/MISSING:\s*([^\n]+)/);
            const tipMatch     = data.result.match(/TIP:\s*([^\n]+)/);

            const score   = scoreMatch   ? Math.min(100, parseInt(scoreMatch[1]))   : 0;
            const matched = matchedMatch ? matchedMatch[1].split(',').map(k => k.trim()).filter(Boolean) : [];
            const missing = missingMatch ? missingMatch[1].split(',').map(k => k.trim()).filter(Boolean) : [];
            const tip     = tipMatch     ? tipMatch[1].trim() : 'Review the job description for key terms and add them naturally to your CV.';

            // Animate score ring
            const circumference = 2 * Math.PI * 50; // 314.16
            const offset = circumference - (score / 100) * circumference;
            const { ring, label, labelClass } = getScoreColor(score);

            atsScoreRing.style.stroke = ring;
            atsScoreRing.style.strokeDashoffset = circumference; // reset
            setTimeout(() => { atsScoreRing.style.strokeDashoffset = offset; }, 50);

            // Animate counter
            let current = 0;
            const step = Math.ceil(score / 40);
            const counter = setInterval(() => {
                current = Math.min(current + step, score);
                atsScoreValue.textContent = current;
                if (current >= score) clearInterval(counter);
            }, 30);

            atsScoreLabel.textContent = label;
            atsScoreLabel.className = `text-center text-sm font-bold ${labelClass}`;

            // Render keyword chips
            atsMatchedKW.innerHTML = matched.length
                ? matched.map(k => `<span class="px-2.5 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-[10px] font-bold rounded-full uppercase tracking-wide">${k}</span>`).join('')
                : '<span class="text-xs text-gray-400">No direct keyword matches found.</span>';

            atsMissingKW.innerHTML = missing.length
                ? missing.map(k => `<span class="px-2.5 py-1 bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-[10px] font-bold rounded-full uppercase tracking-wide">${k}</span>`).join('')
                : '<span class="text-xs text-gray-400">Great — no critical missing keywords!</span>';

            atsTipText.textContent = tip;

            atsLoading.classList.add('hidden');
            atsResults.classList.remove('hidden');

        } catch (err) {
            console.error('ATS error:', err);
            alert('ATS scan failed. Please try again.');
            atsInputSec.classList.remove('hidden');
            atsLoading.classList.add('hidden');
        }
    }

    atsScanBtn?.addEventListener('click', openAtsModal);
    atsCloseBtn?.addEventListener('click', closeAtsModal);
    atsBackdrop?.addEventListener('click', closeAtsModal);
    atsRunBtn?.addEventListener('click', runAtsScan);
    atsRescanBtn?.addEventListener('click', () => {
        atsResults.classList.add('hidden');
        atsInputSec.classList.remove('hidden');
        atsJobDesc.value = '';
    });

    // ============================================================
    // Cover Letter Modal Logic
    // ============================================================
    const clModal        = document.getElementById('cl-modal');
    const clBackdrop     = document.getElementById('cl-backdrop');
    const clOpenBtn      = document.getElementById('cover-letter-btn');
    const clCloseBtn     = document.getElementById('cl-close-btn');
    const clGenerateBtn  = document.getElementById('cl-generate-btn');
    const clRegenerateBtn= document.getElementById('cl-regenerate-btn');
    const clExportPdfBtn = document.getElementById('cl-export-pdf-btn');
    const clExportDocxBtn= document.getElementById('cl-export-docx-btn');
    const clCopyBtn      = document.getElementById('cl-copy-btn');
    const clInputSec     = document.getElementById('cl-input-section');
    const clLoading      = document.getElementById('cl-loading');
    const clResultSec    = document.getElementById('cl-result-section');
    const clLetterText   = document.getElementById('cl-letter-text');
    const clMetaRole     = document.getElementById('cl-meta-role');
    const clMetaCompany  = document.getElementById('cl-meta-company');

    function openClModal() {
        clModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        // Pre-fill job title from CV
        const clJobTitle = document.getElementById('cl-job-title');
        if (clJobTitle && !clJobTitle.value && cvData.personalInfo?.jobTitle) {
            clJobTitle.value = cvData.personalInfo.jobTitle;
        }
    }
    function closeClModal() {
        clModal.classList.add('hidden');
        document.body.style.overflow = '';
    }

    async function generateCoverLetter() {
        const company    = document.getElementById('cl-company').value.trim();
        const manager    = document.getElementById('cl-manager').value.trim();
        const jobTitle   = document.getElementById('cl-job-title').value.trim();
        const jobDesc    = document.getElementById('cl-job-desc').value.trim();

        if (!jobTitle) { alert('Please enter the job title you are applying for.'); return; }

        // Build CV text summary
        const cvText = [
            cvData.personalInfo?.summary || '',
            (cvData.experience || []).map(e => `${e.jobTitle} at ${e.company}: ${(e.responsibilities || '').replace(/<[^>]+>/g, ' ')}`).join(' '),
            (cvData.skills?.technical || []).join(', '),
            (cvData.skills?.soft || []).join(', '),
            (cvData.education || []).map(e => `${e.degree} from ${e.school}`).join(', ')
        ].join(' ').replace(/\s+/g, ' ').slice(0, 3000);

        clInputSec.classList.add('hidden');
        clLoading.classList.remove('hidden');
        clResultSec.classList.add('hidden');

        try {
            const res = await fetch('/api/ai/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'cover-letter',
                    input: cvText,
                    stream: true,
                    context: {
                        companyName: company || 'the company',
                        hiringManager: manager,
                        jobTitle: jobTitle,
                        jobDescription: jobDesc,
                        targetTone: document.getElementById('ai-tone-selector')?.value || 'Professional'
                    }
                })
            });

            if (res.status === 429) {
                alert('Too many requests — please wait a moment and try again.');
                clInputSec.classList.remove('hidden');
                clLoading.classList.add('hidden');
                return;
            }

            clLoading.classList.add('hidden');
            clResultSec.classList.remove('hidden');
            
            clMetaRole.textContent = jobTitle;
            clMetaCompany.textContent = company || '—';
            clLetterText.value = '';

            const contentType = res.headers.get('content-type');
            if (contentType && contentType.includes('application/json')) {
                const data = await res.json();
                if (data.result) clLetterText.value = data.result;
            } else {
                const reader = res.body.getReader();
                const decoder = new TextDecoder('utf-8');
                let buffer = '';

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    buffer += decoder.decode(value, { stream: true });
                    let newlineIndex;

                    while ((newlineIndex = buffer.indexOf('\n\n')) >= 0) {
                        const currentEvent = buffer.slice(0, newlineIndex);
                        buffer = buffer.slice(newlineIndex + 2);

                        const dataLine = currentEvent.split('\n').find(l => l.startsWith('data: '));
                        if (dataLine) {
                            const dataStr = dataLine.slice(6);
                            if (dataStr === '[DONE]') break;
                            try {
                                const parsed = JSON.parse(dataStr);
                                if (parsed.text) {
                                    clLetterText.value += parsed.text;
                                    clLetterText.scrollTop = clLetterText.scrollHeight;
                                }
                            } catch (e) { }
                        }
                    }
                }
            }

        } catch (err) {
            console.error('Cover letter error:', err);
            alert('Failed to generate cover letter. Please try again.');
            clInputSec.classList.remove('hidden');
            clLoading.classList.add('hidden');
        }
    }

    async function exportCoverLetter(format) {
        const letterText = clLetterText.value.trim();
        if (!letterText) { alert('No letter to export.'); return; }

        const company  = document.getElementById('cl-company').value.trim();
        const jobTitle = document.getElementById('cl-job-title').value.trim();
        const btn = format === 'pdf' ? clExportPdfBtn : clExportDocxBtn;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<span class="animate-pulse">Exporting...</span>';
        btn.disabled = true;

        try {
            const res = await fetch(`/cv-editor/${CV_ID}/cover-letter/export/${format}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ letterText, companyName: company, jobTitle })
            });

            if (!res.ok) throw new Error('Export failed');

            const blob = await res.blob();
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `Cover_Letter.${format === 'pdf' ? 'pdf' : 'docx'}`;
            a.click();
            URL.revokeObjectURL(url);
        } catch (err) {
            alert('Export failed. Please try again.');
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    clOpenBtn?.addEventListener('click', openClModal);
    clCloseBtn?.addEventListener('click', closeClModal);
    clBackdrop?.addEventListener('click', closeClModal);
    clGenerateBtn?.addEventListener('click', generateCoverLetter);
    clRegenerateBtn?.addEventListener('click', () => {
        clResultSec.classList.add('hidden');
        clInputSec.classList.remove('hidden');
    });
    clExportPdfBtn?.addEventListener('click', () => exportCoverLetter('pdf'));
    clExportDocxBtn?.addEventListener('click', () => exportCoverLetter('docx'));
    clCopyBtn?.addEventListener('click', () => {
        navigator.clipboard.writeText(clLetterText.value).then(() => {
            clCopyBtn.innerHTML = '<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
            setTimeout(() => {
                clCopyBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
            }, 2000);
        });
    });

    // ============================================================
    // CV Review Modal Logic
    // ============================================================
    const reviewModal    = document.getElementById('review-modal');
    const reviewBackdrop = document.getElementById('review-backdrop');
    const reviewOpenBtn  = document.getElementById('cv-review-btn');
    const reviewCloseBtn = document.getElementById('review-close-btn');
    const reviewLoading  = document.getElementById('review-loading');
    const reviewResults  = document.getElementById('review-results');
    const reviewRerunBtn = document.getElementById('review-rerun-btn');

    function openReviewModal() {
        reviewModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        runCvReview();
    }
    function closeReviewModal() {
        reviewModal.classList.add('hidden');
        document.body.style.overflow = '';
    }

    async function runCvReview() {
        reviewLoading.classList.remove('hidden');
        reviewResults.classList.add('hidden');

        // Reset score
        document.getElementById('review-score-ring').style.strokeDashoffset = '314';
        document.getElementById('review-score-value').textContent = '0';

        const cvText = [
            `SUMMARY: ${cvData.personalInfo?.summary || 'None'}`,
            `EXPERIENCE: ${(cvData.experience || []).map(e => `${e.jobTitle} at ${e.company}: ${(e.responsibilities || '').replace(/<[^>]+>/g, ' ')}`).join(' | ') || 'None'}`,
            `TECHNICAL SKILLS: ${(cvData.skills?.technical || []).join(', ') || 'None'}`,
            `SOFT SKILLS: ${(cvData.skills?.soft || []).join(', ') || 'None'}`,
            `EDUCATION: ${(cvData.education || []).map(e => `${e.degree} from ${e.school} (${e.year || ''}) - ${(e.description || '').replace(/<[^>]+>/g, ' ')}`).join(' | ') || 'None'}`
        ].join('\\n\\n').slice(0, 15000);

        try {
            const res = await fetch('/api/ai/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'cv-review',
                    input: cvText,
                    context: {
                        jobTitle: cvData.personalInfo?.jobTitle || 'General Professional'
                    }
                })
            });

            if (res.status === 429) {
                alert('Too many requests. Please wait a minute and try again.');
                closeReviewModal();
                return;
            }

            const data = await res.json();
            if (!data.result) throw new Error('Empty result');

            // Parse structured output
            const lines = data.result.split('\n').filter(l => l.trim());
            const parsed = {
                score: 0, level: '', verdict: '',
                strengths: [], weaknesses: [], actions: []
            };

            lines.forEach(line => {
                const text = line.trim();
                if (text.startsWith('SCORE:')) parsed.score = parseInt(text.replace('SCORE:', '').trim()) || 0;
                else if (text.startsWith('LEVEL:')) parsed.level = text.replace('LEVEL:', '').trim();
                else if (text.startsWith('VERDICT:')) parsed.verdict = text.replace('VERDICT:', '').trim();
                else if (text.startsWith('STRENGTH_')) parsed.strengths.push(text.split(':').slice(1).join(':').trim());
                else if (text.startsWith('WEAKNESS_')) parsed.weaknesses.push(text.split(':').slice(1).join(':').trim());
                else if (text.startsWith('ACTION_')) parsed.actions.push(text.split(':').slice(1).join(':').trim());
            });

            // Populate UI
            const bdg = document.getElementById('review-level-badge');
            bdg.textContent = parsed.level;
            bdg.className = 'inline-block text-xs font-black uppercase tracking-widest px-3 py-1 rounded-full mb-2 ' + 
                (parsed.score >= 80 ? 'bg-emerald-100 text-emerald-700' : 
                 parsed.score >= 60 ? 'bg-amber-100 text-amber-700' : 'bg-rose-100 text-rose-700');

            document.getElementById('review-verdict').textContent = parsed.verdict;

            // Lists
            const buildList = (items, colorClass, iconHtml) => items.map(item => `
                <div class="flex items-start space-x-2">
                    <span class="mt-0.5 ${colorClass}">${iconHtml}</span>
                    <span class="text-xs text-gray-700 dark:text-slate-300 font-medium">${item}</span>
                </div>
            `).join('');

            document.getElementById('review-strengths').innerHTML = buildList(parsed.strengths.slice(0, 3), 'text-emerald-500', '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>');
            document.getElementById('review-weaknesses').innerHTML = buildList(parsed.weaknesses.slice(0, 3), 'text-rose-400', '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>');
            document.getElementById('review-actions').innerHTML = buildList(parsed.actions.slice(0, 3), 'text-emerald-600', '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/></svg>');

            reviewLoading.classList.add('hidden');
            reviewResults.classList.remove('hidden');

            // Animate Score
            setTimeout(() => {
                const ring = document.getElementById('review-score-ring');
                const valEl = document.getElementById('review-score-value');
                const offset = 314 - (parsed.score / 100) * 314;
                ring.style.strokeDashoffset = offset;
                ring.style.stroke = parsed.score >= 80 ? '#10b981' : parsed.score >= 60 ? '#f59e0b' : '#ef4444';
                
                let current = 0;
                const incr = parsed.score / 30; // 30 frames
                const ival = setInterval(() => {
                    current += incr;
                    if (current >= parsed.score) { current = parsed.score; clearInterval(ival); }
                    valEl.textContent = Math.round(current);
                }, 40);
            }, 100);

        } catch (err) {
            console.error('Review Error:', err);
            alert('Could not analyse CV at this moment. Please try again.');
            closeReviewModal();
        }
    }

    reviewOpenBtn?.addEventListener('click', openReviewModal);
    reviewCloseBtn?.addEventListener('click', closeReviewModal);
    reviewBackdrop?.addEventListener('click', closeReviewModal);
    reviewRerunBtn?.addEventListener('click', runCvReview);
</script>

