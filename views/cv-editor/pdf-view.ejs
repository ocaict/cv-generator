<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Export - <%= cv.title %></title>
    <!-- Tailwind CSS (Static CSS for PDF Reliability) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <% 
    const fontPairs = {
        'outfit-inter': { heading: "'Outfit', sans-serif", body: "'Inter', sans-serif" },
        'serif-inter': { heading: "'EB Garamond', serif", body: "'Inter', sans-serif" },
        'inter-inter': { heading: "'Inter', sans-serif", body: "'Inter', sans-serif" }
    };
    const pair = fontPairs[cv.fontPairing || 'outfit-inter'] || fontPairs['outfit-inter'];
    
    const densityMap = {
        'tight': { margin: '0.75rem', padding: '1.5rem' },
        'standard': { margin: '1.5rem', padding: '3rem' },
        'airy': { margin: '2.5rem', padding: '4rem' }
    };
    const density = densityMap[cv.density || 'standard'] || densityMap['standard'];
    %>
    <style>
        :root {
            --primary: <%= cvData.themeColor || '#4f46e5' %>;
            --font-heading: <%= pair.heading %>;
            --font-body: <%= pair.body %>;
            --section-margin: <%= density.margin %>;
            --page-padding: <%= density.padding %>;
        }
        @page {
            margin: 0;
            padding: 0;
            size: A4;
        }
        body {
            font-family: var(--font-body);
            background-color: white;
            margin: 0;
            padding: 0;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        h1, h2, h3, h4, .font-heading { font-family: var(--font-heading); }
        .section-mb { margin-bottom: var(--section-margin); }
        .page-p { padding: var(--page-padding); }
        
        /* Dynamic Theme Overrides */
        .text-indigo-600, .text-indigo-700 { color: var(--primary) !important; }
        .bg-indigo-50 { background-color: color-mix(in srgb, var(--primary), white 92%) !important; }
        .bg-indigo-600, .bg-indigo-700 { background-color: var(--primary) !important; }
        .border-indigo-600, .border-indigo-700 { border-color: var(--primary) !important; }

        .quill-content p { margin-bottom: 0.5rem; }
        .quill-content p:last-child { margin-bottom: 0; }
        .quill-content ul { list-style-type: disc; padding-left: 1.25rem; margin-bottom: 0.5rem; }
        .quill-content ol { list-style-type: decimal; padding-left: 1.25rem; margin-bottom: 0.5rem; }
        .quill-content, .quill-content *, #preview-content, #preview-content * { color: #111827 !important; }
    </style>
</head>
<body>
<div class="p-0 m-0">
    <% 
    // Section Mapping for easy lookup
    const sectionMap = {
        profile: { path: 'profile', data: { summary: cvData.personalInfo.summary } },
        experience: { path: 'experience', data: { experience: cvData.experience } },
        education: { path: 'education', data: { education: cvData.education } },
        skills: { path: 'skills', data: { skills: cvData.skills } },
        contact: { path: 'contact', data: { personalInfo: cvData.personalInfo } },
        details: { path: 'details', data: { personalInfo: cvData.personalInfo } },
        interests: { path: 'interests', data: { hobbies: cvData.hobbies } },
        references: { path: 'references', data: { references: cvData.references, referencesOnRequest: cvData.referencesOnRequest } }
    };

    // Default order if none exists
    const order = cvData.sectionOrder || {
        main: ['profile', 'experience', 'interests', 'references'],
        sidebar: ['contact', 'details', 'skills', 'education']
    };

    // Filter out dynamically hidden sections
    if (cvData.sectionVisibility) {
        Object.keys(cvData.sectionVisibility).forEach(key => {
            if (cvData.sectionVisibility[key] === false) {
                delete sectionMap[key];
            }
        });
    }
    %>

    <% if (cv.templateId === 'modern' || cv.templateId === 'onyx') { %>
        <!-- Modern & Onyx Template -->
        <div class="max-w-4xl mx-auto min-h-screen <%= cv.templateId === 'onyx' ? 'bg-[#020617] text-[#e2e8f0]' : 'bg-white' %>" <%= cv.templateId === 'onyx' ? 'id="onyx-container"' : '' %>>
            <% if (cv.templateId === 'onyx') { %>
            <style>
                #onyx-container .text-gray-900 { color: #ffffff !important; }
                #onyx-container .text-gray-800 { color: #f8fafc !important; }
                #onyx-container .text-gray-700 { color: #e2e8f0 !important; }
                #onyx-container .text-gray-600 { color: #94a3b8 !important; }
                #onyx-container .text-gray-500 { color: #64748b !important; }
                #onyx-container .text-gray-400 { color: #475569 !important; }
                #onyx-container .border-gray-100 { border-color: #1e293b !important; }
                #onyx-container .border-gray-200 { border-color: #334155 !important; }
                #onyx-container .bg-white { background-color: transparent !important; }
                #onyx-container .bg-gray-50 { background-color: rgba(255,255,255,0.03) !important; }
                #onyx-container .bg-gray-100 { background-color: rgba(255,255,255,0.06) !important; }
                #onyx-container .bg-gray-200 { background-color: rgba(255,255,255,0.1) !important; }
            </style>
            <% } %>

            <%- include('../templates/partials/header', { personalInfo: cvData.personalInfo, template: 'modern', photoStyle: cvData.photoStyle }) %>

            <div class="grid grid-cols-3 gap-8 px-12 pb-12">
                <!-- Sidebar -->
                <aside class="col-span-1 <%= cvData.sidebarPos === 'right' ? 'order-last border-l pl-8' : 'border-r pr-8' %> border-gray-100">
                    <% order.sidebar.forEach(sid => { if (sectionMap[sid]) { %>
                        <%- include('../templates/partials/' + sectionMap[sid].path, { ...sectionMap[sid].data, template: 'modern', sidebarStyle: cvData.sidebarStyle, showHeaderIcons: cvData.showHeaderIcons }) %>
                    <% }}) %>
                </aside>
                
                <!-- Main Content -->
                <div class="col-span-2">
                    <% order.main.forEach(sid => { if (sectionMap[sid]) { %>
                        <%- include('../templates/partials/' + sectionMap[sid].path, { ...sectionMap[sid].data, template: 'modern', sidebarStyle: cvData.sidebarStyle, showHeaderIcons: cvData.showHeaderIcons }) %>
                    <% }}) %>
                </div>
            </div>
        </div>

    <% } else if (cv.templateId === 'classic') { %>
        <!-- Classic Template -->
        <div class="max-w-4xl mx-auto bg-white min-h-screen px-12 py-12 text-gray-900">
            <%- include('../templates/partials/header', { personalInfo: cvData.personalInfo, template: 'classic' }) %>
            
            <% // Single column: combine sidebar and main into one sequence %>
            <div class="space-y-10">
                <% [...order.main, ...order.sidebar].forEach(sid => { if (sectionMap[sid] && sid !== 'contact') { %>
                    <%- include('../templates/partials/' + sectionMap[sid].path, { ...sectionMap[sid].data, template: 'classic', showHeaderIcons: cvData.showHeaderIcons }) %>
                <% }}) %>
            </div>
        </div>

    <% } else if (cv.templateId === 'grid') { %>
        <!-- Grid Template -->
        <div class="max-w-4xl mx-auto bg-white min-h-screen px-12 py-12 text-gray-900">
            <%- include('../templates/partials/header', { personalInfo: cvData.personalInfo, template: 'grid' }) %>
            
            <div class="grid grid-cols-2 gap-12 mt-10">
                <div class="space-y-10">
                    <% order.main.forEach(sid => { if (sectionMap[sid]) { %>
                        <%- include('../templates/partials/' + sectionMap[sid].path, { ...sectionMap[sid].data, template: 'grid', showHeaderIcons: cvData.showHeaderIcons }) %>
                    <% }}) %>
                </div>
                <div class="space-y-10">
                    <% order.sidebar.forEach(sid => { if (sectionMap[sid]) { %>
                        <%- include('../templates/partials/' + sectionMap[sid].path, { ...sectionMap[sid].data, template: 'grid', showHeaderIcons: cvData.showHeaderIcons }) %>
                    <% }}) %>
                </div>
            </div>
        </div>

    <% } else if (cv.templateId === 'standard_professional') { %>
        <!-- Standard Professional Template -->
        <div class="standard-professional-template max-w-4xl mx-auto bg-white min-h-[1123px] px-16 py-16 text-left" style="font-family: Arial, Helvetica, sans-serif;">
            <style>
                .shrink-li-margins ul { list-style-type: disc !important; margin-left: 1.5rem !important; margin-top: 0.25rem !important; }
                .shrink-li-margins li { margin-bottom: 0.25rem !important; }
                .shrink-li-margins p { margin-bottom: 0.25rem !important; }
                .section-header { font-size: 13px; font-weight: 700; border-bottom: 2px solid var(--primary, #4f46e5); padding-bottom: 4px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--primary, #4f46e5); margin-top: 24px; }
            </style>
            
            <% const fullName = `${cvData.personalInfo.firstName || ''} ${cvData.personalInfo.lastName || ''}`.trim() || 'Your Name'; %>
            
            <div class="text-center mb-6">
                <h1 class="text-3xl font-bold text-gray-900 uppercase tracking-tight mb-2"><%= fullName %></h1>
                <p class="text-[11px] text-gray-800 mb-1 flex flex-wrap justify-center gap-2">
                    <% if (cvData.personalInfo.address) { %><span><%= cvData.personalInfo.address %></span><% } %>
                    <% if (cvData.personalInfo.city) { %><span><%= cvData.personalInfo.city %></span><% } %>
                    <% if (cvData.personalInfo.zipCode) { %><span><%= cvData.personalInfo.zipCode %></span><% } %>
                </p>
                <p class="text-[11px] text-gray-800 flex flex-wrap justify-center gap-x-3 gap-y-1">
                    <% if (cvData.personalInfo.phone) { %><span><%= cvData.personalInfo.phone %></span><% } %>
                    <% if (cvData.personalInfo.phone && cvData.personalInfo.email) { %><span class="text-gray-400">|</span><% } %>
                    <% if (cvData.personalInfo.email) { %><span><%= cvData.personalInfo.email %></span><% } %>
                    <% if ((cvData.personalInfo.phone || cvData.personalInfo.email) && (cvData.personalInfo.linkedin || cvData.personalInfo.website)) { %><span class="text-gray-400">|</span><% } %>
                    <% if (cvData.personalInfo.linkedin) { %><span><%= cvData.personalInfo.linkedin.replace(/^https?:\/\/(www\.)?/, '') %></span><% } %>
                    <% if (cvData.personalInfo.website) { %><span class="text-gray-400">|</span><span><%= cvData.personalInfo.website.replace(/^https?:\/\/(www\.)?/, '') %></span><% } %>
                </p>
            </div>
            
            <div class="text-left space-y-2">
                <% 
                const combinedOrder = [...(order.sidebar || []), ...(order.main || [])].filter(id => id !== 'contact');
                combinedOrder.forEach(sid => { 
                    if (sectionMap[sid]) { 
                        if (sid === 'profile') { %>
                            <section class="section-profile">
                                <h2 class="section-header">Professional Summary</h2>
                                <div class="text-[11px] leading-relaxed text-gray-800 quill-content"><%- cvData.personalInfo.summary || '' %></div>
                            </section>
                        <% } else if (sid === 'experience') { %>
                            <section class="section-experience">
                                <h2 class="section-header">Experience</h2>
                                <div class="space-y-4">
                                    <% cvData.experience.forEach(exp => { %>
                                        <div>
                                            <div class="flex justify-between items-baseline mb-0.5">
                                                <span class="text-xs font-bold text-gray-900"><%= exp.jobTitle %></span>
                                                <% 
                                                    let duration = "";
                                                    if (exp.startMonth || exp.startYear) duration += `${exp.startMonth || ''} ${exp.startYear || ''}`.trim();
                                                    if (duration && (exp.isPresent || exp.endMonth || exp.endYear)) duration += " — ";
                                                    if (exp.isPresent) { duration += "Present"; } else if (exp.endMonth || exp.endYear) { duration += `${exp.endMonth || ''} ${exp.endYear || ''}`.trim(); }
                                                %>
                                                <span class="text-[10px] whitespace-nowrap font-medium text-gray-700"><%= duration %></span>
                                            </div>
                                            <p class="text-[11px] font-medium text-gray-800 mb-1"><%= exp.company %></p>
                                            <div class="text-[11px] text-gray-800 leading-relaxed quill-content shrink-li-margins"><%- exp.responsibilities %></div>
                                        </div>
                                    <% }); %>
                                </div>
                            </section>
                        <% } else if (sid === 'education') { %>
                            <section class="section-education">
                                <h2 class="section-header">Education</h2>
                                <div class="space-y-3">
                                    <% cvData.education.forEach(edu => { %>
                                        <div>
                                            <div class="flex justify-between items-baseline mb-0.5">
                                                <span class="text-xs font-bold text-gray-900"><%= edu.degree %></span>
                                                <% const eYear = `${edu.endMonth || ''} ${edu.endYear || ''}`.trim(); %>
                                                <span class="text-[10px] whitespace-nowrap font-medium text-gray-700"><%= eYear %></span>
                                            </div>
                                            <p class="text-[11px] text-gray-800"><%= edu.school %></p>
                                            <% if (edu.description) { %>
                                                <div class="text-[10px] text-gray-600 leading-relaxed quill-content mt-1 shrink-li-margins"><%- edu.description %></div>
                                            <% } %>
                                        </div>
                                    <% }); %>
                                </div>
                            </section>
                        <% } else if (sid === 'skills') { %>
                            <section class="section-skills">
                                <h2 class="section-header">Skills</h2>
                                <p class="text-[11px] text-gray-800"><strong>Technical:</strong> <%= cvData.skills?.technical?.join(', ') || '' %></p>
                                <p class="text-[11px] text-gray-800 mt-1"><strong>Soft Skills:</strong> <%= cvData.skills?.soft?.join(', ') || '' %></p>
                            </section>
                        <% } else if (sid === 'details') { %>
                            <% if (cvData.personalInfo.dateOfBirth || cvData.personalInfo.nationality || cvData.personalInfo.maritalStatus || cvData.personalInfo.drivingLicense) { %>
                            <section class="section-details">
                                <h2 class="section-header">Details</h2>
                                <div class="grid grid-cols-2 gap-2 text-[11px] text-gray-800">
                                    <% if (cvData.personalInfo.dateOfBirth) { %><li>Birth: <span><%= cvData.personalInfo.dateOfBirth %></span></li><% } %>
                                    <% if (cvData.personalInfo.nationality) { %><li>Nat: <span><%= cvData.personalInfo.nationality %></span></li><% } %>
                                    <% if (cvData.personalInfo.maritalStatus) { %><li>Status: <span><%= cvData.personalInfo.maritalStatus %></span></li><% } %>
                                    <% if (cvData.personalInfo.drivingLicense) { %><li>DL: <span><%= cvData.personalInfo.drivingLicense %></span></li><% } %>
                                </div>
                            </section>
                            <% } %>
                        <% } else if (sid === 'interests' && cvData.hobbies && cvData.hobbies.length > 0) { %>
                            <section class="section-interests">
                                <h2 class="section-header">Interests</h2>
                                <p class="text-[11px] text-gray-800"><%= cvData.hobbies.join(', ') %></p>
                            </section>
                        <% } else if (sid === 'references' && (cvData.referencesOnRequest || (cvData.references && cvData.references.length > 0))) { %>
                            <section class="section-references">
                                <h2 class="section-header">References</h2>
                                <% if (cvData.referencesOnRequest) { %>
                                    <p class="text-[11px] italic text-gray-600">References available on request</p>
                                <% } else { %>
                                    <div class="grid grid-cols-2 gap-4 mt-2">
                                        <% cvData.references.forEach(ref => { %>
                                            <div>
                                                <h4 class="text-[11px] font-bold text-gray-900"><%= ref.name %></h4>
                                                <p class="text-[10px] text-gray-600 uppercase mb-1"><%= ref.company %></p>
                                                <p class="text-[10px] text-gray-800"><%= ref.email %></p>
                                                <% if (ref.phone) { %><p class="text-[10px] text-gray-800"><%= ref.phone %></p><% } %>
                                            </div>
                                        <% }); %>
                                    </div>
                                <% } %>
                            </section>
                        <% } 
                    } 
                }); %>
            </div>
        </div>
    <% } else { %>
        <!-- Minimalist Template (Default) -->
        <div class="max-w-4xl mx-auto bg-white min-h-screen px-20 py-20 text-gray-800 font-outfit">
            <%- include('../templates/partials/header', { personalInfo: cvData.personalInfo, template: 'minimalist' }) %>
            <%- include('../templates/partials/contact', { personalInfo: cvData.personalInfo, template: 'minimalist' }) %>

            <div class="space-y-12 max-w-3xl mx-auto px-12">
                <% [...order.main, ...order.sidebar].filter(s => s !== 'contact' && s !== 'profile').forEach(sid => { if (sectionMap[sid]) { %>
                    <%- include('../templates/partials/' + sectionMap[sid].path, { ...sectionMap[sid].data, template: 'minimalist' }) %>
                <% }}) %>
            </div>
        </div>
    <% } %>

</div>
</body>
</html>

