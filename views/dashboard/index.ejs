<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Sophisticated Header Group -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-8">
        <div class="animate-fade-in">
            <h1 class="text-4xl font-extrabold font-outfit text-gray-900 dark:text-white mb-2 tracking-tight">
                <% 
                    const hour = new Date().getHours();
                    let greeting = "Good morning";
                    if(hour >= 12 && hour < 17) greeting = "Good afternoon";
                    else if(hour >= 17) greeting = "Good evening";
                %>
                <%= greeting %>, <%= (user.name || user.email.split('@')[0]).split(' ')[0] %>!
            </h1>
            <p class="text-gray-500 dark:text-slate-400 font-medium text-lg">Your professional portfolio is looking sharp. Keep it updated!</p>
        </div>
        
        <a href="/cv-editor/create" class="flex items-center space-x-2 bg-indigo-600 text-white px-8 py-4 rounded-2xl font-bold hover:bg-indigo-700 hover:scale-105 active:scale-95 transition-all shadow-xl shadow-indigo-100 dark:shadow-none uppercase tracking-widest text-xs">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            <span>Create New CV</span>
        </a>
    </div>

    <!-- Quick Stats Bar (Premium Glassmorphism) -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
        <div class="bg-white/60 dark:bg-slate-800/60 backdrop-blur-xl border border-gray-100 dark:border-slate-700 p-6 rounded-3xl shadow-sm flex items-center space-x-4">
            <div class="w-12 h-12 bg-indigo-50 dark:bg-indigo-900/30 rounded-2xl flex items-center justify-center text-indigo-600 dark:text-indigo-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-[0.2em] leading-none mb-1">Total Versions</p>
                <p class="text-2xl font-black text-gray-900 dark:text-white leading-none"><%= stats.total %></p>
            </div>
        </div>
        
        <div class="bg-white/60 dark:bg-slate-800/60 backdrop-blur-xl border border-gray-100 dark:border-slate-700 p-6 rounded-3xl shadow-sm flex items-center space-x-4">
            <div class="w-12 h-12 bg-green-50 dark:bg-green-900/30 rounded-2xl flex items-center justify-center text-green-600 dark:text-green-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-[0.2em] leading-none mb-1">Public Links</p>
                <p class="text-2xl font-black text-gray-900 dark:text-white leading-none"><%= stats.publicCount %></p>
            </div>
        </div>

        <div class="bg-white/60 dark:bg-slate-800/60 backdrop-blur-xl border border-gray-100 dark:border-slate-700 p-6 rounded-3xl shadow-sm flex items-center space-x-4">
            <div class="w-12 h-12 bg-amber-50 dark:bg-amber-900/30 rounded-2xl flex items-center justify-center text-amber-600 dark:text-amber-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
            </div>
            <div>
                <p class="text-[10px] font-black text-gray-400 dark:text-slate-500 uppercase tracking-[0.2em] leading-none mb-1">Styles Used</p>
                <p class="text-2xl font-black text-gray-900 dark:text-white leading-none"><%= stats.templateCount %></p>
            </div>
        </div>
    </div>

    <!-- CV Grid Section Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
        <h2 class="text-xs font-black text-gray-400 dark:text-slate-500 uppercase tracking-[0.3em]">Your CV Collection</h2>
        <div class="flex-grow h-px hidden sm:block mx-6 bg-gray-100 dark:bg-slate-800"></div>
        <div class="relative w-full sm:w-64">
            <input type="text" id="cv-search" placeholder="Search CVs..." class="w-full bg-white dark:bg-slate-800 border border-gray-100 dark:border-slate-700 rounded-xl px-4 py-2 text-xs font-bold text-gray-600 dark:text-white outline-none focus:ring-2 focus:ring-indigo-500 transition-all pl-10">
            <svg class="w-4 h-4 absolute left-3 top-2.5 text-gray-300 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
    </div>

    <% if (cvs && cvs.length > 0) { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <% cvs.forEach(cv => { %>
                <div class="group relative bg-white dark:bg-slate-800 rounded-[2.5rem] border border-gray-100 dark:border-slate-700 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col">
                    <!-- Mini-Preview Wrapper -->
                    <div class="aspect-[4/3] bg-gray-50 dark:bg-slate-900 relative overflow-hidden flex items-center justify-center p-6 border-b border-gray-50 dark:border-slate-800">
                        <img src="/images/template_<%= cv.templateId %>.png" class="w-full h-full object-contain transform group-hover:scale-110 transition-transform duration-700 shadow-xl rounded-md origin-bottom" alt="Preview">
                        
                        <!-- Status Badge Overlay -->
                        <div class="absolute top-4 right-4">
                            <% if (cv.isPublic) { %>
                                <span class="bg-green-500 text-white text-[8px] font-black px-3 py-1.5 rounded-full uppercase tracking-widest shadow-lg shadow-green-100 dark:shadow-none flex items-center">
                                    <span class="w-1.5 h-1.5 bg-white rounded-full mr-2 animate-pulse"></span>
                                    LIVE
                                </span>
                            <% } else { %>
                                <span class="bg-gray-400 text-white text-[8px] font-black px-3 py-1.5 rounded-full uppercase tracking-widest">DRAFT</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="p-8 flex-grow flex flex-col">
                        <div class="flex items-start justify-between mb-2">
                            <h3 class="text-xl font-black text-gray-900 dark:text-white leading-tight group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors uppercase tracking-tight truncate mr-4"><%= cv.title %></h3>
                            <span class="text-[9px] font-black text-gray-300 dark:text-slate-600 uppercase tracking-widest border border-gray-100 dark:border-slate-700 px-2 py-1 rounded-lg"><%= cv.templateId %></span>
                        </div>
                        <p class="text-[10px] text-gray-400 dark:text-slate-500 font-bold mb-8 uppercase tracking-widest flex items-center">
                            <svg class="w-3 h-3 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Edited <%= cv.relativeTime %>
                        </p>
                        
                        <div class="mt-auto flex items-center gap-3">
                            <a href="/cv-editor/<%= cv.id %>" class="flex-grow bg-indigo-600 text-white text-center py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100 active:scale-95">
                                Edit Resume
                            </a>
                            
                            <!-- Action Dropdown or Inline buttons -->
                            <div class="flex gap-2">
                                <a href="/cv-editor/<%= cv.id %>/duplicate" title="Duplicate CV" class="w-12 h-12 flex items-center justify-center bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-500 rounded-2xl hover:text-indigo-600 dark:hover:text-indigo-400 hover:border-indigo-100 dark:hover:border-slate-600 hover:bg-white dark:hover:bg-slate-800 transition-all active:scale-90">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"></path></svg>
                                </a>

                                <a href="/cv-editor/<%= cv.id %>/delete" title="Delete" class="w-12 h-12 flex items-center justify-center bg-gray-50 dark:bg-slate-900 border border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-500 rounded-2xl hover:text-red-500 hover:border-red-100 hover:bg-white dark:hover:bg-slate-800 transition-all active:scale-90" onclick="return confirm('Delete this CV version permanently?')">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
            
            <!-- Empty Slot Trigger -->
            <a href="/cv-editor/create" class="group border-2 border-dashed border-gray-200 dark:border-slate-800 rounded-[2.5rem] flex flex-col items-center justify-center p-12 hover:border-indigo-300 dark:hover:border-indigo-900 hover:bg-indigo-50/10 transition-all min-h-[400px]">
                <div class="w-16 h-16 bg-gray-50 dark:bg-slate-900 rounded-2xl flex items-center justify-center text-gray-300 dark:text-slate-700 group-hover:bg-indigo-100 group-hover:text-indigo-600 transition-all mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                </div>
                <h3 class="text-sm font-black text-gray-400 dark:text-slate-600 uppercase tracking-[0.2em] group-hover:text-indigo-600 transition-all">New Version</h3>
            </a>
        </div>
    <% } else { %>
        <div class="text-center py-32 bg-white/60 dark:bg-slate-800/60 backdrop-blur-xl rounded-[3rem] border-2 border-dashed border-gray-100 dark:border-slate-700 animate-fade-in shadow-sm">
            <div class="w-24 h-24 bg-gray-50 dark:bg-slate-900 rounded-[2rem] flex items-center justify-center mx-auto mb-8 text-gray-200 dark:text-slate-700">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <h2 class="text-3xl font-black text-gray-900 dark:text-white mb-3 tracking-tight">Your Journey Starts Here</h2>
            <p class="text-gray-400 dark:text-slate-500 mb-10 max-w-sm mx-auto font-medium">Create your first high-impact CV today and unlock new professional opportunities.</p>
            <a href="/cv-editor/create" class="inline-flex items-center space-x-3 bg-indigo-600 text-white px-10 py-4 rounded-2xl font-bold hover:bg-indigo-700 hover:scale-105 transition-all shadow-xl shadow-indigo-100 dark:shadow-none uppercase tracking-widest text-xs">
                 <span>Generate First CV</span>
                 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
        </div>
    <% } %>
</div>

<script>
    document.getElementById('cv-search')?.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        const cards = document.querySelectorAll('.grid > .group');
        
        cards.forEach(card => {
            const title = card.querySelector('h3')?.textContent.toLowerCase() || '';
            const isMatch = title.includes(query);
            
            if (isMatch) {
                card.style.display = 'flex';
                card.style.opacity = '1';
                card.style.transform = 'scale(1)';
            } else {
                card.style.opacity = '0';
                card.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    if (card.style.opacity === '0') card.style.display = 'none';
                }, 300);
            }
        });
    });
</script>

