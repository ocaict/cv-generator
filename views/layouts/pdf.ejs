<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Export</title>
    <!-- Tailwind CSS (Static CSS for PDF Reliability) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        @page {
            margin: 0;
            padding: 0;
            size: A4;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: white;
            margin: 0;
            padding: 0;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .quill-content p { margin-bottom: 0.5rem; }
        .quill-content p:last-child { margin-bottom: 0; }
        .quill-content ul { list-style-type: disc; padding-left: 1.25rem; margin-bottom: 0.5rem; }
        .quill-content ol { list-style-type: decimal; padding-left: 1.25rem; margin-bottom: 0.5rem; }
    </style>
</head>
<body>
    <%- body %>
</body>
</html>
