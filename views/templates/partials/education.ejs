<!-- views/templates/partials/education.ejs -->
<section class="<%= template === 'modern' ? 'mb-10 animate-fade-in' : 
                 template === 'classic' ? 'mb-8 border-t border-gray-200 pt-6' : 
                 'mb-12 border-b border-gray-100 pb-8 last:border-0' %> section-education">
    <% 
        const icons = {
            education: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z M12 14l9-5-9-5-9 5 9 5zm0 0v6m0-6L3 9m18 0l-9 5"></path></svg>'
        };
        const showIcons = (typeof showHeaderIcons !== 'undefined' && showHeaderIcons === 'icons');
    %>
    <h2 class="<%= template === 'modern' ? 'text-xs font-bold text-indigo-600 uppercase tracking-widest mb-4' : 
                  template === 'classic' ? 'text-xs font-bold border-b border-gray-200 pb-1 mb-3 uppercase tracking-widest text-gray-900 font-outfit' : 
                  'text-[10px] font-black text-indigo-600 uppercase tracking-[0.35em] mb-6 border-b border-gray-100 pb-3' %> flex items-center gap-2 heading-education">
        <% if (showIcons) { %>
            <span class="opacity-60"><%- icons.education %></span>
        <% } %>
        <span>Education</span>
    </h2>
    <div class="<%= template === 'modern' ? 'space-y-5' : 
                   template === 'classic' ? 'space-y-4' : 
                   'grid grid-cols-2 gap-12 pt-4' %>">
        <% education.forEach(edu => { %>
            <div class="education-item">
                <div class="<%= template === 'modern' ? 'flex justify-between items-start mb-2' : 
                             template === 'classic' ? 'flex justify-between text-sm font-bold' : 
                             'flex justify-between items-baseline mb-2' %>">
                    <h4 class="<%= template === 'modern' ? 'text-[11px] font-bold text-gray-900 mb-1' : 
                                 template === 'classic' ? 'text-gray-900' : 
                                 'text-base font-bold text-gray-900' %>">
                        <%= edu.degree %>
                    </h4>
                    <span class="<%= template === 'modern' ? 'hidden' : 
                                 template === 'classic' ? 'text-gray-400 font-outfit' : 
                                 'text-[10px] font-black text-gray-300 uppercase tracking-widest font-outfit' %>">
                        <%= edu.year %>
                    </span>
                </div>
                <p class="<%= template === 'modern' ? 'text-[9px] text-gray-400 font-bold uppercase leading-tight' : 
                             template === 'classic' ? 'text-indigo-600 italic text-xs font-bold' : 
                             'text-sm font-bold text-indigo-600 mb-4 tracking-tight leading-none' %>">
                    <%= edu.school %>
                </p>
                <% if (template === 'modern') { %>
                    <p class="text-[9px] text-gray-500 font-bold mt-1"><%= edu.year %></p>
                <% } %>
                <% if (edu.description) { %>
                    <div class="<%= template === 'modern' ? 'text-[10px] text-gray-600 leading-relaxed mt-1 quill-content' : 
                                   template === 'classic' ? 'text-xs text-gray-600 leading-relaxed font-serif mt-2 quill-content' : 
                                   'text-[11px] text-gray-600 leading-relaxed font-medium mt-2 quill-content' %>">
                        <%- edu.description %>
                    </div>
                <% } %>
            </div>
        <% }) %>
    </div>
</section>
