<!-- views/templates/partials/interests.ejs -->
<% if (hobbies && hobbies.length > 0) { %>
<section class="<%= template === 'modern' ? 'mb-10' : 
                 template === 'classic' ? 'mb-8 border-t border-gray-200 pt-6' : 
                 'mb-12 border-b border-gray-100 pb-8 last:border-0' %> section-interests">
    <% 
        const icons = {
            interests: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>'
        };
        const showIcons = (typeof showHeaderIcons !== 'undefined' && showHeaderIcons === 'icons');
    %>
    <h2 class="<%= template === 'modern' ? 'text-xs font-bold text-indigo-600 uppercase tracking-widest mb-4' : 
                  template === 'classic' ? 'text-xs font-bold border-b border-gray-200 pb-1 mb-3 uppercase tracking-widest text-gray-900 font-outfit' : 
                  'text-[10px] font-black text-indigo-600 uppercase tracking-[0.35em] mb-4 border-b border-gray-100 pb-3' %> flex items-center gap-2 heading-interests">
        <% if (showIcons) { %>
            <span class="opacity-60"><%- icons.interests %></span>
        <% } %>
        <span>Interests</span>
    </h2>
    <div class="<%= template === 'modern' ? 'text-[11px] text-gray-600 font-medium' : 
                   template === 'classic' ? 'text-xs text-gray-700 font-serif' : 
                   'text-[11px] font-bold text-gray-800 leading-loose' %> interests-content">
        <%= hobbies.join(' • ') %>
    </div>
</section>
<% } %>
